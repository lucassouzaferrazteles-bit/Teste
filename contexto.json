// Exemplo de hook no método de callback de resposta
void (*original_OnLoginResponse)(void*, proto_MajorLoginRes_o*);
void hooked_OnLoginResponse(void* this_ptr, proto_MajorLoginRes_o* response) {
    ProcessLoginResponse(response);
    original_OnLoginResponse(this_ptr, response);
}
