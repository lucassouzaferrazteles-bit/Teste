                    let str = this.buf.readCString(len);
                    let jwt = cleanJWT(str);
                    if (jwt) {
                        console.log("\n🎫 JWT ENCONTRADO NA RESPOSTA!");
                        console.log(`   ${jwt}`);
                        decodeJWT(jwt);
                        flowData.jwt = jwt;
                    } else {
                        // Procurar nos bytes brutos
                        let raw = this.buf.readByteArray(len);
                        let rawBytes = new Uint8Array(raw);
                        for (let i = 0; i < rawBytes.length - 20; i++) {
                            if (rawBytes[i] === 0x65 && rawBytes[i+1] === 0x79 && rawBytes[i+2] === 0x4A) {
                                let jwt = "";
                                for (let j = i; j < rawBytes.length && rawBytes[j] !== 0x00 && j < i + 500; j++) {
                                    jwt += String.fromCharCode(rawBytes[j]);
                                }
                                if (jwt.length > 50 && jwt.split('.').length === 3) {
                                    console.log("\n🎫 JWT ENCONTRADO NOS BYTES BRUTOS!");
                                    console.log(`   ${jwt}`);
                                    decodeJWT(jwt);
                                    flowData.jwt = jwt;
                                    break;
                                }
                            }
                        }
                    }
                } catch(e) {}
            }
        }
    });
}

function decodeJWT(jwt) {
    try {
        let parts = jwt.split('.');
        let payload = JSON.parse(Buffer.from(parts[1], 'base64').toString());
        console.log("\n📦 JWT PAYLOAD:");
        console.log(JSON.stringify(payload, null, 2));
        flowData.account_id = payload.account_id;
