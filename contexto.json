javascript
// save as: jwt_capture_with_log.js
// frida -U "Free Fire" -l jwt_capture_with_log.js

// ==================== CONFIGURAÇÃO DE LOG ====================
var logFile = "/sdcard/jwt_capture_log.txt";
var logContent = "";

function logToFile(msg) {
    var timestamp = new Date().toISOString();
    var line = "[" + timestamp + "] " + msg + "\n";
    logContent += line;
    console.log(msg);
    
    // Tentar salvar a cada 10 linhas
    if (logContent.split('\n').length > 10) {
        saveLog();
    }
}

function saveLog() {
    try {
        var File = Java.use("java.io.File");
        var FileWriter = Java.use("java.io.FileWriter");
        var file = File.$new(logFile);
        var writer = FileWriter.$new(file);
        writer.write(logContent);
        writer.close();
        logContent = "";
    } catch(e) {
        console.log("Erro ao salvar log: " + e);
    }
}

// ==================== CAPTURAR JWT ====================
var found = false;
var jwtFound = null;

function extractJWT(str) {
    if (!str) return null;
    var match = str.match(/eyJ[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+/);
    return match ? match[0] : null;
}

// Hook SSL_read para capturar respostas
var sslRead = Module.findExportByName("libssl.so", "SSL_read");
if (sslRead) {
    Interceptor.attach(sslRead, {
        onEnter: function(args) {
            this.buf = args[1];
            this.len = args[2].toInt32();
        },
        onLeave: function(retval) {
            if (found) return;
            var len = retval.toInt32();
            if (len > 200 && len < 10000) {
                try {
                    var str = this.buf.readCString(Math.min(len, 2000));
                    var jwt = extractJWT(str);
                    if (jwt) {
                        found = true;
                        jwtFound = jwt;
                        
                        var result = "\n" + "=".repeat(60) + "\n";
                        result += "✅ JWT CAPTURADO!\n";
                        result += "=".repeat(60) + "\n";
                        result += jwt + "\n";
                        result += "=".repeat(60) + "\n";
                        
                        // Decodificar JWT
                        try {
                            var parts = jwt.split('.');
                            var payload = JSON.parse(Buffer.from(parts[1], 'base64').toString());
                            result += "\n📦 PAYLOAD:\n";
                            result += JSON.stringify(payload, null, 2);
                            result += "\n\n🆔 Account ID: " + payload.account_id + "\n";
                        } catch(e) {}
                        
                        logToFile(result);
                        
                        // Mostrar comando para extrair via ADB
                        logToFile("\n💾 Para extrair o log:\n");
                        logToFile("   adb pull " + logFile + "\n");
                    }
                } catch(e) {}
            }
        }
    });
    logToFile("✅ SSL_read hook ativo");
}

// Scanner de memória periódico
var scanCount = 0;
var maxScans = 20;

function scanMemory() {
    if (found) return;
    scanCount++;
    logToFile("[*] Scan " + scanCount + "/" + maxScans);
    
    try {
        var ranges = Process.enumerateRanges({ protection: 'r--', coalesce: true });
        for (var i = 0; i < ranges.length && !found; i++) {
            var range = ranges[i];
            if (range.size > 1024 * 1024) continue;
            
            try {
                var data = range.base.readCString(Math.min(range.size, 512 * 1024));
                var jwt = extractJWT(data);
                if (jwt && jwt !== jwtFound) {
                    found = true;
                    logToFile("\n✅ JWT ENCONTRADO NA MEMÓRIA!\n" + jwt);
                }
            } catch(e) {}
        }
    } catch(e) {}
    
    if (!found && scanCount < maxScans) {
        setTimeout(scanMemory, 3000);
    } else if (!found) {
        logToFile("\n⚠️ JWT não encontrado após " + maxScans + " scans");
    }
}

// ==================== INICIAR ====================
logToFile("\n" + "=".repeat(60));
logToFile("🔑 CAPTURANDO JWT - COM LOG");
logToFile("=".repeat(60));
logToFile("Log file: " + logFile);

// Aguardar libil2cpp.so
var waitInterval = setInterval(function() {
    var mod = Process.findModuleByName("libil2cpp.so");
    if (mod) {
        clearInterval(waitInterval);
        logToFile("[*] libil2cpp.so encontrado");
        logToFile("[*] Iniciando capture...");
        setTimeout(scanMemory, 3000);
    }
}, 1000);
