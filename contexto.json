📜 Scripts PowerShell para Análise Completa das DLLs
1️⃣ Script Principal: Analisar Todas as DLLs
powershell
# Save as: Analyze-DLLs.ps1
#Execute na pasta que contém as DLLs do jogo

param(
    [string]$DllPath = ".",
    [string]$OutputFile = "DLL_Analysis_Complete.txt"
)

Write-Host "========================================" -ForegroundColor Cyan
Write-Host "ANALISANDO DLLS DO JOGO" -ForegroundColor Cyan
Write-Host "========================================" -ForegroundColor Cyan

# Criar arquivo de saída
$global:Output = @()
$global:Output += "=== ANALISE DE DLLS - $(Get-Date) ==="
$global:Output += ""

# Função para adicionar ao output
function Add-Output {
    param([string]$Text)
    $global:Output += $Text
    Write-Host $Text -ForegroundColor Gray
}

# 1. Listar todas as DLLs
Add-Output "`n=== DLLS ENCONTRADAS ==="
$dlls = Get-ChildItem -Path $DllPath -Filter "*.dll" -Recurse
foreach ($dll in $dlls) {
    Add-Output "  $($dll.FullName)"
}

# 2. Verificar se temos as DLLs principais
$gameAssembly = Get-ChildItem -Path $DllPath -Filter "GameAssembly.dll" -Recurse
$unityPlayer = Get-ChildItem -Path $DllPath -Filter "UnityPlayer.dll" -Recurse

if ($gameAssembly) {
    Add-Output "`n✓ GameAssembly.dll encontrada!"
} else {
    Add-Output "`n✗ GameAssembly.dll NÃO encontrada!"
}

# 3. Usar dumpbin se disponível (Visual Studio)
$dumpbin = Get-Command dumpbin.exe -ErrorAction SilentlyContinue

if ($dumpbin) {
    Add-Output "`n=== EXPORTS DAS DLLS (dumpbin) ==="
    
    foreach ($dll in $dlls) {
        Add-Output "`n--- $($dll.Name) ---"
        $exports = & dumpbin /exports $dll.FullName 2>$null | Select-String -Pattern "Login|Auth|SDK|Garena|MSDK"
        if ($exports) {
            $exports | ForEach-Object { Add-Output "  $_" }
        } else {
            Add-Output "  Nenhuma função relevante encontrada"
        }
    }
} else {
    Add-Output "`n⚠ dumpbin não encontrado. Instale Visual Studio ou Windows SDK."
}

# 4. Usar ILSpyCMD se disponível (recomendado)
$ilspy = Get-Command ilspycmd.exe -ErrorAction SilentlyContinue

if ($ilspy) {
    Add-Output "`n=== DECOMPILAÇÃO COM ILSPY ==="
    
    if ($gameAssembly) {
        Add-Output "`nDecompilando GameAssembly.dll..."
        $tempFile = "$env:TEMP\gameassembly_decompiled.cs"
        & ilspycmd $gameAssembly.FullName -o $tempFile 2>$null
        
        if (Test-Path $tempFile) {
            Add-Output "  ✓ Decompilação concluída!"
            
            # Buscar classes de login
            Add-Output "`n--- Classes com 'Login' ---"
            Select-String -Path $tempFile -Pattern "class.*Login" | ForEach-Object {
                Add-Output "  $($_.Line.Trim())"
            }
            
            # Buscar métodos de login
            Add-Output "`n--- Métodos de Login ---"
            Select-String -Path $tempFile -Pattern "Login\s*\(" | ForEach-Object {
                Add-Output "  $($_.Line.Trim())"
            }
            
            # Buscar referências ao Garena MSDK
            Add-Output "`n--- Referências ao Garena MSDK ---"
            Select-String -Path $tempFile -Pattern "Garena|MSDK" | Select-Object -First 20 | ForEach-Object {
                Add-Output "  $($_.Line.Trim())"
            }
        }
    }
} else {
    Add-Output "`n⚠ ilspycmd não encontrado. Instale com: dotnet tool install -g ilspycmd"
}

# 5. Análise de strings nas DLLs
Add-Output "`n=== STRINGS RELEVANTES NAS DLLS ==="

foreach ($dll in $dlls) {
    Add-Output "`n--- $($dll.Name) ---"
    
    # Extrair strings usando PowerShell
    $strings = & strings.exe $dll.FullName 2>$null | Select-String -Pattern "Login|Auth|Garena|MSDK|token|password|account"
    
    if ($strings) {
        $strings | Select-Object -First 10 | ForEach-Object {
            Add-Output "  $_"
        }
    } else {
        Add-Output "  Nenhuma string relevante encontrada"
    }
}

# 6. Verificar dependências
Add-Output "`n=== DEPENDÊNCIAS DAS DLLS ==="

foreach ($dll in $dlls) {
    Add-Output "`n--- $($dll.Name) ---"
    $deps = & dumpbin /dependents $dll.FullName 2>$null | Select-String -Pattern ".dll"
    if ($deps) {
        $deps | Select-Object -First 10 | ForEach-Object {
            Add-Output "  $_"
        }
    }
}

# 7. Gerar relatório completo
$outputPath = Join-Path $DllPath $OutputFile
$global:Output | Out-File -FilePath $outputPath -Encoding UTF8

Write-Host "`n========================================" -ForegroundColor Green
Write-Host "ANÁLISE CONCLUÍDA!" -ForegroundColor Green
Write-Host "Relatório salvo em: $outputPath" -ForegroundColor Yellow
Write-Host "========================================" -ForegroundColor Green

# Abrir o arquivo automaticamente
if (Test-Path $outputPath) {
    Start-Process notepad.exe $outputPath
}
2️⃣ Script Específico: Buscar Funções de Login nas DLLs
powershell
# Save as: Find-LoginFunctions.ps1

param(
    [string]$DllPath = "."
)

Write-Host "========================================" -ForegroundColor Magenta
Write-Host "BUSCANDO FUNÇÕES DE LOGIN NAS DLLS" -ForegroundColor Magenta
Write-Host "========================================" -ForegroundColor Magenta

$results = @()
$results += "=== FUNÇÕES DE LOGIN ENCONTRADAS ==="

# Palavras-chave para busca
$keywords = @(
    "Login", "Auth", "Authenticate", "SignIn", "SignOn",
    "Garena", "MSDK", "SDK", "Account", "User", "Password",
    "Token", "Session", "Validate", "Verify", "Callback"
)

# Buscar em todas as DLLs
$dlls = Get-ChildItem -Path $DllPath -Filter "*.dll" -Recurse

foreach ($dll in $dlls) {
    Write-Host "Analisando: $($dll.Name)" -ForegroundColor Cyan
    
    # Usar dumpbin para exports
    $exports = & dumpbin /exports $dll.FullName 2>$null
    
    if ($exports) {
        foreach ($keyword in $keywords) {
            $matches = $exports | Select-String -Pattern $keyword -CaseSensitive:$false
            if ($matches) {
                $results += "`n--- $($dll.Name) - $keyword ---"
                $matches | ForEach-Object {
                    $line = $_.Line.Trim()
                    $results += "  $line"
                    Write-Host "  $line" -ForegroundColor Green
                }
            }
        }
    }
    
    # Tentar ler como assembly .NET
    try {
        $assembly = [System.Reflection.Assembly]::LoadFile($dll.FullName)
        $types = $assembly.GetTypes()
        
        foreach ($type in $types) {
            foreach ($keyword in $keywords) {
                if ($type.Name -match $keyword) {
                    $results += "  Tipo: $($type.FullName)"
                    Write-Host "  Tipo: $($type.FullName)" -ForegroundColor Yellow
                    
                    # Listar métodos
                    $methods = $type.GetMethods() | Where-Object { $_.Name -match $keyword }
                    foreach ($method in $methods) {
                        $results += "    Método: $($method.Name)"
                        Write-Host "    Método: $($method.Name)" -ForegroundColor Gray
                    }
                }
            }
        }
    }
    catch {
        # Não é assembly .NET gerenciado (provavelmente nativo)
        Write-Host "  (DLL nativa - pulando análise gerenciada)" -ForegroundColor DarkGray
    }
}

$outputFile = "LoginFunctions_Found.txt"
$results | Out-File -FilePath $outputFile -Encoding UTF8

Write-Host "`nResultados salvos em: $outputFile" -ForegroundColor Green
3️⃣ Script para Extrair Metadados das DLLs
powershell
# Save as: Extract-DLL-Metadata.ps1

param(
    [string]$DllPath = ".",
    [string]$OutputFile = "DLL_Metadata.json"
)

Write-Host "Extraindo metadados das DLLs..." -ForegroundColor Cyan

$metadata = @{
    Timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    Dlls = @()
}

$dlls = Get-ChildItem -Path $DllPath -Filter "*.dll" -Recurse

foreach ($dll in $dlls) {
    $dllInfo = @{
        Name = $dll.Name
        FullPath = $dll.FullName
        Size = $dll.Length
        LastModified = $dll.LastWriteTime
        VersionInfo = @{}
        ExportedFunctions = @()
        Dependencies = @()
    }
    
    # Obter versão
    $version = [System.Diagnostics.FileVersionInfo]::GetVersionInfo($dll.FullName)
    $dllInfo.VersionInfo = @{
        FileVersion = $version.FileVersion
        ProductVersion = $version.ProductVersion
        CompanyName = $version.CompanyName
        Description = $version.FileDescription
    }
    
    # Tentar extrair exports (dumpbin)
    $exports = & dumpbin /exports $dll.FullName 2>$null
    if ($exports) {
        $exportLines = $exports | Select-String -Pattern "\s+\d+\s+[0-9A-F]+\s+[0-9A-F]+\s+\S+" 
        foreach ($line in $exportLines) {
            $parts = $line.Trim() -split '\s+'
            if ($parts.Count -ge 4) {
                $dllInfo.ExportedFunctions += $parts[-1]
            }
        }
    }
    
    $metadata.Dlls += $dllInfo
}

# Salvar como JSON
$metadata | ConvertTo-Json -Depth 10 | Out-File -FilePath $OutputFile -Encoding UTF8

Write-Host "Metadados salvos em: $OutputFile" -ForegroundColor Green
Write-Host "Total de DLLs analisadas: $($metadata.Dlls.Count)" -ForegroundColor Yellow
