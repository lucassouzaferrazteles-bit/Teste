// save as: JWT_v2.js
// frida -U "Free Fire" -l JWT_v2.js

console.log("\n🎯 CAPTURANDO JWT DO MAJOR LOGIN - V2\n");

// ==================== OFFSETS DO DUMP ====================
// proto_MajorLoginRes_Fields
// account_id: offset 0x10 (8 bytes)
// token: offset 0x18 (ponteiro para string)
// server_url: offset 0x1C
// ttl: offset 0x20

// ==================== FUNÇÃO PARA LER STRING IL2CPP ====================
function readIl2CppString(ptr) {
    if (!ptr || ptr.isNull()) return "";
    try {
        // Estrutura da string IL2CPP: [klass][monitor][length][chars]
        const length = ptr.add(8).readS32();
        if (length > 0 && length < 4096) {
            return ptr.add(12).readUtf8String(length);
        }
    } catch(e) {}
    return "";
}

// ==================== EXTRAIR JWT DE DADOS BINÁRIOS ====================
function extractJWTFromRawData(bytes) {
    // Procurar pelo padrão JWT (eyJ...)
    for (let i = 0; i < bytes.length - 20; i++) {
        // "eyJ" em ASCII = 0x65, 0x79, 0x4A
        if (bytes[i] === 0x65 && bytes[i+1] === 0x79 && bytes[i+2] === 0x4A) {
            let jwt = "";
            for (let j = i; j < bytes.length && bytes[j] !== 0x00 && j < i + 500; j++) {
                if (bytes[j] >= 0x20 && bytes[j] <= 0x7E) { // ASCII imprimível
                    jwt += String.fromCharCode(bytes[j]);
                } else {
                    break;
                }
            }
            if (jwt.length > 50 && jwt.split('.').length === 3) {
                return jwt;
            }
        }
    }
    
    // Tentar buscar sequências que parecem base64 (JWT)
    const base64Pattern = /[A-Za-z0-9_-]{20,}/g;
    const str = Array.from(bytes).map(b => String.fromCharCode(b)).join('');
    const matches = str.match(base64Pattern);
    if (matches) {
        for (let m of matches) {
            if (m.length > 50 && m.split('.').length === 3) {
                return m;
            }
        }
    }
    return null;
}

// ==================== 1. HOOK SSL_READ PARA CAPTURAR RESPOSTA BRUTA ====================
function captureRawResponse() {
    const sslRead = Module.findExportByName("libssl.so", "SSL_read");
    if (!sslRead) return;
    
    Interceptor.attach(sslRead, {
        onEnter: function(args) {
            this.buf = args[1];
            this.len = args[2].toInt32();
        },
        onLeave: function(retval) {
            const len = retval.toInt32();
            if (len > 200 && len < 20000) {
                try {
                    const rawBytes = this.buf.readByteArray(Math.min(len, 5000));
                    const bytes = new Uint8Array(rawBytes);
                    
                    // Tentar extrair JWT
                    const jwt = extractJWTFromRawData(bytes);
                    if (jwt) {
                        console.log("\n╔════════════════════════════════════════════════════════════╗");
                        console.log("🎯 JWT CAPTURADO NA RESPOSTA SSL!");
                        console.log("╚════════════════════════════════════════════════════════════╝");
                        console.log(`\n${jwt}\n`);
                        
                        // Decodificar JWT
                        try {
                            const parts = jwt.split('.');
                            const payload = JSON.parse(Buffer.from(parts[1], 'base64').toString());
                            console.log("📦 PAYLOAD:");
                            console.log(JSON.stringify(payload, null, 2));
                            console.log(`\n🆔 ACCOUNT ID: ${payload.account_id}`);
                        } catch(e) {
                            console.log("⚠️ Não foi possível decodificar o JWT");
                        }
                    } else if (len > 500) {
                        // Mostrar primeiros bytes para debug
                        console.log(`\n📥 RESPOSTA SSL (${len} bytes) - PRIMEIROS BYTES:`);
                        console.log(Array.from(bytes.slice(0, 100)).map(b => b.toString(16).padStart(2,'0')).join(' '));
                    }
                } catch(e) {}
            }
        }
    });
    console.log("✅ SSL_read hooked - capturando respostas brutas");
}

// ==================== 2. ESCANEAR MEMÓRIA CORRETAMENTE ====================
function scanMemoryForJWT() {
    let lastJWT = null;
    
    setInterval(() => {
        try {
            const ranges = Process.enumerateRanges({ protection: 'r--', coalesce: true });
            for (let range of ranges) {
                if (range.size > 5 * 1024 * 1024) continue;
                try {
                    const data = range.base.readByteArray(Math.min(range.size, 1024 * 1024));
                    const bytes = new Uint8Array(data);
                    
                    const jwt = extractJWTFromRawData(bytes);
                    if (jwt && jwt !== lastJWT) {
                        lastJWT = jwt;
                        console.log("\n╔════════════════════════════════════════════════════════════╗");
                        console.log("🎯 JWT ENCONTRADO NA MEMÓRIA!");
                        console.log("╚════════════════════════════════════════════════════════════╝");
                        console.log(`\n${jwt}\n`);
                        
                        try {
                            const parts = jwt.split('.');
                            const payload = JSON.parse(Buffer.from(parts[1], 'base64').toString());
                            console.log("📦 PAYLOAD:");
                            console.log(JSON.stringify(payload, null, 2));
                            console.log(`\n🆔 ACCOUNT ID: ${payload.account_id}`);
                        } catch(e) {}
                    }
                } catch(e) {}
            }
        } catch(e) {}
    }, 2000);
    console.log("✅ Scanner de memória ativo");
}

