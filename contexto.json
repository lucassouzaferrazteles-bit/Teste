function scanMemoryForJWT() {
    setInterval(() => {
        try {
            const ranges = Process.enumerateRanges({ protection: 'r--', coalesce: true });
            for (let range of ranges) {
                if (range.size > 1024 * 1024) continue;
                try {
                    const matches = Memory.scanSync(range.base, Math.min(range.size, 1024*1024), "65 79 4A");
                    for (let match of matches) {
                        try {
                            const str = match.address.readCString(400);
                            if (str && str.startsWith("eyJ")) {
