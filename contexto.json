powershell
# Save as: Extract-LoginClasses.ps1

param(
    [string]$DllPath = "."
)

Write-Host "========================================" -ForegroundColor Cyan
Write-Host "EXTRAINDO CLASSES DE LOGIN" -ForegroundColor Cyan
Write-Host "========================================" -ForegroundColor Cyan

Add-Type -AssemblyName System.Reflection

$outputFile = "LoginClasses_Extracted.txt"
$results = @()

$dlls = Get-ChildItem -Path $DllPath -Filter "*.dll" -Recurse

foreach ($dll in $dlls) {
    try {
        $assembly = [System.Reflection.Assembly]::LoadFile($dll.FullName)
        $types = $assembly.GetTypes()
        
        foreach ($type in $types) {
            # Verificar se é classe de login
            $isLoginClass = $false
            $className = $type.Name
            
            if ($className -match "Login|Auth|Account|SDK|Garena|MSDK|User|Credential") {
                $isLoginClass = $true
            }
            
            # Verificar atributos
            $attrs = $type.CustomAttributes
            foreach ($attr in $attrs) {
                if ($attr.AttributeType.Name -match "Login|Auth") {
                    $isLoginClass = $true
                    break
                }
            }
            
            if ($isLoginClass) {
                $results += "`n=== DLL: $($dll.Name) ==="
                $results += "Classe: $($type.FullName)"
                $results += "Namespace: $($type.Namespace)"
                $results += "Tipo: $($type.Attributes)"
                
                # Propriedades
                $props = $type.GetProperties()
                if ($props.Count -gt 0) {
                    $results += "Propriedades:"
                    foreach ($prop in $props) {
                        $results += "  - $($prop.Name) : $($prop.PropertyType.Name)"
                    }
                }
                
                # Métodos
                $methods = $type.GetMethods() | Where-Object { $_.IsPublic -and $_.Name -notmatch "get_|set_" }
                if ($methods.Count -gt 0) {
                    $results += "Métodos:"
                    foreach ($method in $methods) {
                        $params = ($method.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
                        $results += "  - $($method.Name)($params) : $($method.ReturnType.Name)"
                    }
                }
                
                # Campos
                $fields = $type.GetFields()
                if ($fields.Count -gt 0) {
                    $results += "Campos:"
                    foreach ($field in $fields) {
                        $results += "  - $($field.Name) : $($field.FieldType.Name)"
                    }
                }
                
                $results += "---"
            }
        }
    }
    catch {
        # Ignorar erros de carregamento
    }
}

$outputPath = Join-Path $DllPath $outputFile
$results | Out-File -FilePath $outputPath -Encoding UTF8

Write-Host "`n✅ Extração concluída!" -ForegroundColor Green
Write-Host "📄 Resultados salvos em: $outputPath" -ForegroundColor Yellow

if ($results.Count -eq 0) {
    Write-Host "⚠️ Nenhuma classe de login encontrada nas DLLs." -ForegroundColor Red
    Write-Host "Verifique se o caminho está correto e se as DLLs são assemblies .NET válidos." -ForegroundColor Yellow
}
