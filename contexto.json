3️⃣ Para extrair as estruturas de REQUEST/RESPONSE do login
powershell
$fileName = "il2cpp.h"
$outputFile = "LoginStructures.txt"
$patterns = @("LoginReq", "LoginRes", "SecPlayerLogin", "UserLogin", "TokenLogin", "AuthReq")

Write-Host "Extraindo estruturas de requisição/resposta..." -ForegroundColor Cyan
foreach ($pattern in $patterns) {
    Write-Host "Buscando: $pattern" -ForegroundColor Gray
    Get-Content $fileName -Encoding UTF8 | Select-String -Pattern "\b$pattern\b" -Context 3,10 | Out-File -FilePath $outputFile -Append -Encoding UTF8
    "`n---`n" | Out-File -FilePath $outputFile -Append -Encoding UTF8
}
Write-Host "Estruturas salvas em '$outputFile'" -ForegroundColor Green
4️⃣ Para encontrar a classe principal que GERENCIA o login (COW_UIModelLogin)
powershell
$fileName = "il2cpp.h"
$outputFile = "UIModelLogin.txt"
$searchTerm = "COW_UIModelLogin"

Write-Host "Buscando classe de gerenciamento de login..." -ForegroundColor Cyan
$allLines = Get-Content $fileName -Encoding UTF8
$inClass = $false
$braceCount = 0
$classLines = @()

for ($i = 0; $i -lt $allLines.Count; $i++) {
    $line = $allLines[$i]
    
    if ($line -match "class\s+$searchTerm") {
        $inClass = $true
        $classLines = @($line)
        $braceCount = ($line.ToCharArray() | Where-Object {$_ -eq '{'}).Count - ($line.ToCharArray() | Where-Object {$_ -eq '}'}).Count
        continue
    }
    
    if ($inClass) {
        $classLines += $line
        $openBraces = ($line.ToCharArray() | Where-Object {$_ -eq '{'}).Count
        $closeBraces = ($line.ToCharArray() | Where-Object {$_ -eq '}'}).Count
        $braceCount += $openBraces - $closeBraces
        
        if ($braceCount -eq 0) {
            Write-Host "Classe $searchTerm encontrada!" -ForegroundColor Green
            $classLines | Out-File -FilePath $outputFile -Encoding UTF8
            break
        }
    }
}

if (-not $inClass) {
    Write-Host "Classe $searchTerm não encontrada. Buscando alternativas..." -ForegroundColor Yellow
    Get-Content $fileName -Encoding UTF8 | Select-String -Pattern "ModelLogin|LoginManager|LoginController" -Context 2,15 | Out-File -FilePath $outputFile -Encoding UTF8
}
Write-Host "Resultado salvo em '$outputFile'" -ForegroundColor Green
