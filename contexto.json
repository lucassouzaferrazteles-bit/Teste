✅ Script Correto para Analisar DLLs .NET (C# do Unity)
powershell
# Save as: Analyze-NET-DLLs.ps1
# PARA DLLs GERENCIADAS DO UNITY (Assembly-CSharp.dll, etc.)

param(
    [string]$DllPath = "."
)

Write-Host "========================================" -ForegroundColor Cyan
Write-Host "ANALISANDO DLLs .NET (UNITY/C#)" -ForegroundColor Cyan
Write-Host "========================================" -ForegroundColor Cyan

$outputFile = "NET_DLL_Analysis.txt"
$results = @()
$results += "=== ANÁLISE DE DLLs .NET - $(Get-Date) ==="
$results += ""

# Carregar System.Reflection
Add-Type -AssemblyName System.Reflection

# Função para analisar assembly .NET
function Analyze-DotNetAssembly {
    param([string]$DllPath, [string]$DllName)
    
    $assemblyResults = @()
    $assemblyResults += "`n=== $DllName ==="
    
    try {
        # Carregar o assembly
        $assembly = [System.Reflection.Assembly]::LoadFile($DllPath)
        $assemblyResults += "✓ Assembly carregado com sucesso"
        
        # Obter tipos
        $types = $assembly.GetTypes()
        $assemblyResults += "  Total de tipos: $($types.Count)"
        
        # Buscar classes relacionadas a login
        $loginTypes = $types | Where-Object { 
            $_.Name -match "Login|Auth|Account|User|SDK|Garena|MSDK|Session|Credential|Token|Password" 
        }
        
        if ($loginTypes.Count -gt 0) {
            $assemblyResults += "`n  🎯 CLASSES ENCONTRADAS:"
            foreach ($type in $loginTypes) {
                $assemblyResults += "    - $($type.FullName)"
                
                # Buscar métodos dessas classes
                $methods = $type.GetMethods() | Where-Object { 
                    $_.Name -match "Login|Auth|Sign|Verify|Validate|Connect|GetToken|Authenticate" 
                }
                
                if ($methods.Count -gt 0) {
                    foreach ($method in $methods) {
                        $params = ($method.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
                        $assemblyResults += "        🔹 Método: $($method.Name)($params) -> $($method.ReturnType.Name)"
                    }
                }
            }
        }
        
        # Buscar especificamente por COW_UIModelLogin
        $cowLoginType = $types | Where-Object { $_.Name -eq "COW_UIModelLogin" -or $_.Name -eq "UIModelLogin" }
        if ($cowLoginType) {
            $assemblyResults += "`n  ⭐ CLASSE PRINCIPAL DE LOGIN ENCONTRADA: $($cowLoginType.FullName)"
            
            # Listar todos os métodos públicos
            $publicMethods = $cowLoginType.GetMethods() | Where-Object { $_.IsPublic }
            $assemblyResults += "    Métodos públicos:"
            foreach ($method in $publicMethods) {
                $params = ($method.GetParameters() | ForEach-Object { "$($_.ParameterType.Name) $($_.Name)" }) -join ", "
                $assemblyResults += "      - $($method.Name)($params) : $($method.ReturnType.Name)"
            }
            
            # Listar propriedades
            $properties = $cowLoginType.GetProperties()
            if ($properties.Count -gt 0) {
                $assemblyResults += "    Propriedades:"
                foreach ($prop in $properties) {
                    $assemblyResults += "      - $($prop.Name) : $($prop.PropertyType.Name)"
                }
            }
        }
        
        # Buscar estruturas de requisição/resposta
        $structs = $types | Where-Object { 
            $_.Name -match "LoginReq|LoginRes|SecPlayerLogin|TokenLogin" 
        }
        
        if ($structs.Count -gt 0) {
            $assemblyResults += "`n  📦 ESTRUTURAS DE REQUISIÇÃO/RESPOSTA:"
            foreach ($struct in $structs) {
                $assemblyResults += "    - $($struct.Name)"
                $fields = $struct.GetFields()
                foreach ($field in $fields) {
                    $assemblyResults += "      * $($field.Name) : $($field.FieldType.Name)"
                }
            }
        }
        
    }
    catch {
        $assemblyResults += "✗ Erro ao carregar: $_"
    }
    
    return $assemblyResults
}

# Encontrar todas as DLLs na pasta
$dlls = Get-ChildItem -Path $DllPath -Filter "*.dll" -Recurse

if ($dlls.Count -eq 0) {
    Write-Host "Nenhuma DLL encontrada em: $DllPath" -ForegroundColor Red
    exit
}

Write-Host "Encontradas $($dlls.Count) DLL(s) para analisar:`n" -ForegroundColor Yellow

foreach ($dll in $dlls) {
    Write-Host "Analisando: $($dll.Name)" -ForegroundColor Cyan
    $dllResults = Analyze-DotNetAssembly -DllPath $dll.FullName -DllName $dll.Name
    $results += $dllResults
    Write-Host "  Concluído!" -ForegroundColor Green
}

# Salvar resultados
$outputPath = Join-Path $DllPath $outputFile
$results | Out-File -FilePath $outputPath -Encoding UTF8

Write-Host "`n========================================" -ForegroundColor Green
Write-Host "✓ ANÁLISE CONCLUÍDA!" -ForegroundColor Green
Write-Host "Relatório salvo em: $outputPath" -ForegroundColor Yellow
Write-Host "========================================" -ForegroundColor Green

# Abrir o arquivo
if (Test-Path $outputPath) {
    Start-Process notepad.exe $outputPath
}
