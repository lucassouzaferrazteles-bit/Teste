def generate_guest_credentials():
    """Gera novas credenciais Guest válidas"""
    uid = str(random.randint(4000000000, 4999999999))
    # Senha hash SHA256 de 64 caracteres
    random_seed = secrets.token_hex(32)
    password = hashlib.sha256(random_seed.encode()).hexdigest().upper()
    return uid, password

def encrypt_payload(payload_str):
    cipher = AES.new(AES_KEY, AES.MODE_CBC, AES_IV)
    padded = pad(payload_str.encode('utf-8'), AES.block_size)
    return cipher.encrypt(padded)

def decode_jwt(jwt):
    try:
        parts = jwt.split('.')
        if len(parts) == 3:
            payload = json.loads(base64.b64decode(parts[1] + '==').decode())
            return payload
    except:
        pass
    return None

