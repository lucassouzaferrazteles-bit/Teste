// ==================== FUNÇÃO PARA ENCONTRAR OFFSETS DINAMICAMENTE ====================
void FindLoginOffsetsDynamic() {
    // Padrões de bytes para busca (exemplo - ajuste conforme necessário)
    // Para encontrar a função Login, procure por padrão único no GameAssembly.dll
    
    // Exemplo de assinatura de bytes (você precisa extrair do IDA/Ghidra)
    BYTE loginSignature[] = { 0x55, 0x8B, 0xEC, 0x83, 0xEC, 0x0C }; // Prólogo típico
    
    uintptr_t base = (uintptr_t)GetModuleHandleW(L"GameAssembly.dll");
    if (!base) return;
    
    // Buscar a assinatura
    MEMORY_BASIC_INFORMATION mbi;
    for (uintptr_t addr = base; addr < base + 0x5000000; addr += mbi.RegionSize) {
        if (!VirtualQuery((LPCVOID)addr, &mbi, sizeof(mbi))) break;
        if (mbi.State != MEM_COMMIT || mbi.Protect != PAGE_READONLY && mbi.Protect != PAGE_EXECUTE_READ) continue;
        
        // Buscar padrão
        for (uintptr_t i = addr; i < (uintptr_t)mbi.BaseAddress + mbi.RegionSize - sizeof(loginSignature); i++) {
            if (memcmp((void*)i, loginSignature, sizeof(loginSignature)) == 0) {
                printf("Possível função encontrada em: 0x%llX\n", i - base);
            }
        }
    }
}
