# save as: extract_dump_to_log.py
# python extract_dump_to_log.py

import re
import json
import sys
from pathlib import Path
from datetime import datetime

# ==================== CONFIGURAÇÃO ====================
LOG_FILE = "dump_analysis_log.txt"

def log_print(msg, also_print=True):
    """Salva no log e opcionalmente imprime"""
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    log_msg = f"[{timestamp}] {msg}\n"
    
    with open(LOG_FILE, 'a', encoding='utf-8') as f:
        f.write(log_msg)
    
    if also_print:
        print(msg)

def extract_struct(dump_content, struct_name):
    """Extrai uma struct específica do dump.cs"""
    pattern = rf'struct {struct_name}[^{{]*\{{([^{{}}]*)\}}'
    match = re.search(pattern, dump_content, re.DOTALL)
    
    if match:
        return match.group(0).strip()
    return None

def extract_class(dump_content, class_name):
    """Extrai uma classe específica do dump.cs"""
    # Procura por padrão de classe C#
    pattern = rf'public class {class_name}[^{{]*\{{[^{{}}]*\}}'
    matches = re.findall(pattern, dump_content, re.DOTALL)
    
    if matches:
        return matches[0].strip()
    return None

def extract_fields_from_struct(struct_content):
    """Extrai campos de uma struct"""
    fields = []
    lines = struct_content.split('\n')
    
    for line in lines:
        line = line.strip()
        if line and not line.startswith('//') and not line.startswith('struct') and not line.startswith('{') and not line.startswith('}'):
            # Remove ponto e vírgula
            line = line.rstrip(';')
            if line:
                parts = line.split()
                if len(parts) >= 2:
                    field_type = ' '.join(parts[:-1])
                    field_name = parts[-1]
                    fields.append({
                        'type': field_type,
                        'name': field_name,
                        'line': line
                    })
    return fields

def main():
    print("╔════════════════════════════════════════════════════════════╗")
    print("║     EXTRAINDO DUMP.CS E SALVANDO EM LOG                    ║")
    print("╚════════════════════════════════════════════════════════════╝")
    
    # Limpar log anterior
    if Path(LOG_FILE).exists():
        Path(LOG_FILE).unlink()
    
    log_print("\n" + "="*70)
    log_print("🐍 EXTRAÇÃO DO DUMP.CS")
    log_print(f"Arquivo: dump.cs")
    log_print(f"Data: {datetime.now().isoformat()}")
    log_print("="*70)
    
    # Encontrar dump.cs
    dump_path = Path('dump.cs')
    if not dump_path.exists():
        log_print("❌ dump.cs não encontrado na pasta atual!", True)
        log_print(f"   Pasta atual: {Path.cwd()}", True)
        sys.exit(1)
    
    log_print(f"✅ dump.cs encontrado: {dump_path.absolute()}")
    log_print(f"   Tamanho: {dump_path.stat().st_size:,} bytes")
    
    # Ler conteúdo
    with open(dump_path, 'r', encoding='utf-8', errors='ignore') as f:
        content = f.read()
    
    log_print(f"   Linhas: {len(content.splitlines()):,}")
    
    # ================================================================
    # 1. EXTRAIR tcp_SecPlayerLoginReq
    # ================================================================
    log_print("\n" + "-"*70)
    log_print("📦 [1] tcp_SecPlayerLoginReq_Fields")
    log_print("-"*70)
    
    struct_content = extract_struct(content, 'tcp_SecPlayerLoginReq_Fields')
    if struct_content:
        log_print(f"Struct encontrada:\n{struct_content}\n")
        fields = extract_fields_from_struct(struct_content)
        log_print(f"Campos ({len(fields)}):")
        for f in fields:
            log_print(f"   • {f['name']}: {f['type']}")
    else:
        log_print("❌ struct tcp_SecPlayerLoginReq_Fields não encontrada")
    
    # ================================================================
    # 2. EXTRAIR proto_MajorLoginRes
    # ================================================================
    log_print("\n" + "-"*70)
    log_print("📦 [2] proto_MajorLoginRes_Fields")
    log_print("-"*70)
    
    struct_content = extract_struct(content, 'proto_MajorLoginRes_Fields')
    if struct_content:
        log_print(f"Struct encontrada:\n{struct_content}\n")
        fields = extract_fields_from_struct(struct_content)
        log_print(f"Campos ({len(fields)}):")
        for f in fields:
            log_print(f"   • {f['name']}: {f['type']}")
    else:
        log_print("❌ struct proto_MajorLoginRes_Fields não encontrada")
    
    # ================================================================
    # 3. EXTRAIR CLASSE GarenaMSDKMgr
    # ================================================================
    log_print("\n" + "-"*70)
    log_print("📦 [3] GarenaMSDKMgr")
    log_print("-"*70)
    
    class_content = extract_class(content, 'GarenaMSDKMgr')
    if class_content:
        log_print(f"Classe encontrada (primeiros 500 caracteres):\n{class_content[:500]}...")
    else:
        log_print("⚠️ Classe GarenaMSDKMgr não encontrada")
    
    # ================================================================
    # 4. PROCURAR POR STRINGS IMPORTANTES
    # ================================================================
    log_print("\n" + "-"*70)
    log_print("🔍 [4] Buscando strings importantes")
    log_print("-"*70)
    
    keywords = ['token', 'jwt', 'login', 'auth', 'password', 'secret', 'key', 'aes', 'cbc']
    
    for keyword in keywords:
        lines = []
        for i, line in enumerate(content.split('\n')):
            if keyword.lower() in line.lower() and len(line) < 200:
                lines.append(f"      Linha {i}: {line.strip()[:100]}")
        
        if lines:
            log_print(f"\n   • '{keyword}' encontrado ({len(lines)} ocorrências):")
            for line in lines[:5]:  # Mostrar apenas as 5 primeiras
                log_print(line)
    
    # ================================================================
    # 5. BUSCAR POR OFFSETS (RVA)
    # ================================================================
    log_print("\n" + "-"*70)
    log_print("🔢 [5] Offsets encontrados (RVA)")
    log_print("-"*70)
    
    rva_pattern = r'RVA: 0x([0-9A-Fa-f]+)'
    rva_matches = re.findall(rva_pattern, content)
    
    if rva_matches:
        log_print(f"Total de RVAs encontrados: {len(rva_matches)}")
        # Mostrar primeiros 10
        for i, rva in enumerate(rva_matches[:10]):
            log_print(f"   {i+1}. 0x{rva}")
        if len(rva_matches) > 10:
            log_print(f"   ... e mais {len(rva_matches)-10} offsets")
    
    # ================================================================
    # 6. GERAR PAYLOAD JSON BASEADO NAS ESTRUTURAS
    # ================================================================
    log_print("\n" + "-"*70)
    log_print("🔧 [6] Payload base para replicação")
    log_print("-"*70)
    
    # Buscar valores típicos para os campos
    sample_payload = {
        "area_id": 1,  # Brasil
        "client_version_code": "6.17.3",
        "client_architecture": 2,  # arm64
        "is_new_client": 1,
        "is_reconnect": 0
    }
    
    log_print("Payload recomendado (tcp_SecPlayerLoginReq):")
    log_print(json.dumps(sample_payload, indent=2))
    
    # ================================================================
    # SALVAR RESUMO
    # ================================================================
    log_print("\n" + "="*70)
    log_print("✅ EXTRAÇÃO CONCLUÍDA")
    log_print("="*70)
    log_print(f"📄 Log salvo em: {LOG_FILE}")
    log_print(f"   Tamanho: {Path(LOG_FILE).stat().st_size:,} bytes")

if __name__ == "__main__":
    main()
