};

let requestCounter = 0;
let afterMajorCounter = 0;
let majorLoginCaptured = false;
let stopAfterMajor = false;
const MAX_AFTER_MAJOR = 10;

// ==================== UTILITÁRIOS ====================
function cleanJWT(str) {
    const match = str.match(/eyJ[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+/);
    return match ? match[0] : null;
}

function timestamp() {
    return new Date().toISOString();
}

function printSeparator(title) {
    console.log("\n" + "═".repeat(70));
    console.log(`📌 ${title}`);
    console.log("═".repeat(70));
}

// ==================== 1. CAPTURAR APPSFLYER (ANTES DO GRANT) ====================
function captureAppsFlyer() {
    const sslWrite = Module.findExportByName("libssl.so", "SSL_write");
    if (!sslWrite) return;
    
    Interceptor.attach(sslWrite, {
        onEnter: function(args) {
            if (majorLoginCaptured && stopAfterMajor) return;
            
            const buf = args[1];
            const len = args[2].toInt32();
            
            if (len > 500 && len < 5000) {
                try {
                    const str = buf.readCString(Math.min(len, 300));
                    if (str && str.includes("androidevent") && str.includes("launches.appsflyersdk.com")) {
                        requestCounter++;
                        printSeparator(`[${requestCounter}] APPSFLYER REQUEST (antes do Grant)`);
                        console.log(`   Tamanho: ${len} bytes`);
                        
                        const lines = str.split('\n');
                        console.log(`   ${lines[0]}`);
                        for (let line of lines.slice(1, 10)) {
                            if (line.includes("User-Agent") || line.includes("Content-Type") || line.includes("Host")) {
                                console.log(`   ${line.trim()}`);
                            }
                        }
                        
                        flowData.requests.push({
                            stage: "pre_oauth",
                            type: "appsflyer",
                            method: lines[0],
                            size: len
                        });
                    }
                } catch(e) {}
            }
        }
    });
}

// ==================== 2. CAPTURAR OAUTH GRANT ====================
function captureOAuth() {
    const sslWrite = Module.findExportByName("libssl.so", "SSL_write");
    if (!sslWrite) return;
    
    Interceptor.attach(sslWrite, {
        onEnter: function(args) {
            if (majorLoginCaptured && stopAfterMajor) return;
            
            const buf = args[1];
            const len = args[2].toInt32();
            
            if (len > 200 && len < 800) {
                try {
                    const str = buf.readCString(len);
                    if (str && str.includes("oauth/guest/token:grant")) {
                        requestCounter++;
                        printSeparator(`[${requestCounter}] OAUTH GRANT REQUEST`);
                        
                        const jsonMatch = str.match(/\{.*\}/s);
                        if (jsonMatch) {
                            try {
                                const json = JSON.parse(jsonMatch[0]);
                                console.log(`   📱 UID: ${json.uid}`);
                                console.log(`   🔑 Password: ${json.password.substring(0, 32)}...`);
                                console.log(`   🆔 Client ID: ${json.client_id}`);
                                flowData.credentials = { uid: json.uid, password: json.password };
                                flowData.requests.push({ stage: "oauth", type: "grant", data: json });
                            } catch(e) {}
                        }
                        
                        const lines = str.split('\n');
                        for (let line of lines.slice(0, 8)) {
                            if (line.includes("User-Agent")) {
                                console.log(`   ${line.trim()}`);
                            }
                        }
                    }
                } catch(e) {}
            }
        }
    });
}

// ==================== 3. CAPTURAR RESPOSTA DO OAUTH ====================
function captureOAuthResponse() {
    const sslRead = Module.findExportByName("libssl.so", "SSL_read");
    if (!sslRead) return;
    
    Interceptor.attach(sslRead, {
        onEnter: function(args) {
            this.buf = args[1];
            this.len = args[2].toInt32();
        },
        onLeave: function(retval) {
            if (majorLoginCaptured && stopAfterMajor) return;
            
            const len = retval.toInt32();
            if (len > 100 && len < 5000) {
                try {
                    const str = this.buf.readCString(len);
                    if (str && (str.includes("access_token") || str.includes("refresh_token"))) {
                        printSeparator(`RESPOSTA OAUTH GRANT`);
                        
                        try {
                            const json = JSON.parse(str);
                            console.log(`   ✅ Access Token: ${json.access_token?.substring(0, 50)}...`);
                            console.log(`   🔄 Refresh Token: ${json.refresh_token?.substring(0, 50)}...`);
                            console.log(`   📧 Open ID: ${json.open_id}`);
                            console.log(`   🔗 External ID: ${json.external_id}`);
                            flowData.oauth_response = json;
                            flowData.responses.push({ stage: "oauth", data: json });
                        } catch(e) {}
                    }
                } catch(e) {}
            }
        }
    });
}

// ==================== 4. CAPTURAR MAJOR LOGIN REQUEST ====================
function captureMajorLoginRequest() {
    const sslWrite = Module.findExportByName("libssl.so", "SSL_write");
    if (!sslWrite) return;
    
    Interceptor.attach(sslWrite, {
        onEnter: function(args) {
            if (majorLoginCaptured && stopAfterMajor) return;
            
            const buf = args[1];
            const len = args[2].toInt32();
            
            // MajorLogin tem entre 1700-2500 bytes
            if (len > 1700 && len < 3000) {
                try {
                    const str = buf.readCString(Math.min(len, 200));
                    if (str && str.includes("androidevent")) {
                        requestCounter++;
                        majorLoginCaptured = true;
                        
                        printSeparator(`[${requestCounter}] MAJOR LOGIN REQUEST (CRIPTOGRAFADO)`);
                        console.log(`   📦 Tamanho: ${len} bytes`);
                        
                        const lines = str.split('\n');
                        console.log(`   ${lines[0]}`);
                        for (let line of lines.slice(1, 8)) {
                            if (line.includes("User-Agent") || line.includes("Content-Type") || line.includes("Host")) {
                                console.log(`   ${line.trim()}`);
                            }
                        }
                        
                        // Capturar payload criptografado
                        const bodyStart = str.indexOf('\r\n\r\n');
                        if (bodyStart > 0) {
                            const payloadLen = len - bodyStart - 4;
                            if (payloadLen > 0) {
                                const payload = buf.add(bodyStart + 4).readByteArray(payloadLen);
                                if (payload) {
                                    const hex = Array.from(new Uint8Array(payload)).map(b => b.toString(16).padStart(2,'0')).join(' ');
                                    console.log(`\n🔐 PAYLOAD CRIPTOGRAFADO (${payloadLen} bytes):`);
                                    console.log(`   ${hex.substring(0, 200)}...`);
                                    flowData.major_login_request = { size: len, payload_hex: hex.substring(0, 500) };
                                }
                            }
                        }
                        
                        flowData.requests.push({ stage: "major", type: "request", size: len });
                    }
                } catch(e) {}
            }
        }
    });
}

// ==================== 5. CAPTURAR MAJOR LOGIN RESPONSE (JWT) ====================
function captureMajorLoginResponse() {
    const sslRead = Module.findExportByName("libssl.so", "SSL_read");
    if (!sslRead) return;
    
    Interceptor.attach(sslRead, {
        onEnter: function(args) {
            this.buf = args[1];
            this.len = args[2].toInt32();
        },
        onLeave: function(retval) {
            const len = retval.toInt32();
            if (len > 500 && len < 20000) {
                try {
                    const str = this.buf.readCString(len);
                    if (str) {
                        const jwt = cleanJWT(str);
                        if (jwt) {
                            printSeparator(`MAJOR LOGIN RESPONSE - JWT CAPTURADO!`);
                            console.log(`\n🎫 ${jwt}\n`);
                            
                            flowData.major_login_response = jwt;
                            flowData.jwt = jwt;
                            flowData.responses.push({ stage: "major", jwt: jwt });
                            
                            // Decodificar JWT
                            try {
                                const parts = jwt.split('.');
                                const payload = JSON.parse(Buffer.from(parts[1], 'base64').toString());
                                console.log("📦 JWT PAYLOAD DECODIFICADO:");
                                console.log(JSON.stringify(payload, null, 2));
                                flowData.account_id = payload.account_id;
                                console.log(`\n🆔 ACCOUNT ID: ${payload.account_id}`);
                            } catch(e) {}
                        }
                    }
                } catch(e) {}
            }
        }
    });
}

// ==================== 6. CAPTURAR PRÓXIMAS 10 REQUISIÇÕES APÓS MAJOR LOGIN ====================
function captureAfterMajorLogin() {
    const sslWrite = Module.findExportByName("libssl.so", "SSL_write");
    if (!sslWrite) return;
    
    Interceptor.attach(sslWrite, {
        onEnter: function(args) {
            if (!majorLoginCaptured) return;
            if (afterMajorCounter >= MAX_AFTER_MAJOR) return;
            
            const buf = args[1];
            const len = args[2].toInt32();
            
            if (len > 100 && len < 10000) {
                try {
                    const str = buf.readCString(Math.min(len, 500));
                    if (str && (str.includes("GET") || str.includes("POST"))) {
                        // Pular requisições do AppsFlyer (que continuam rodando)
                        if (str.includes("androidevent") || str.includes("appsflyer")) return;
                        
                        afterMajorCounter++;
                        printSeparator(`[${afterMajorCounter}/10] API APÓS LOGIN`);
                        
                        const lines = str.split('\n');
                        console.log(`   ${lines[0]}`);
                        
                        // Extrair headers importantes
                        for (let line of lines.slice(1, 12)) {
                            if (line.includes("User-Agent") || line.includes("Authorization") || 
                                line.includes("Content-Type") || line.includes("Host") ||
                                line.includes("X-")) {
                                console.log(`   ${line.trim()}`);
                            }
                        }
                        
                        // Se for GET, mostrar parâmetros da URL
                        const urlMatch = str.match(/GET\s+([^\s?]+\?[^\s]+)/);
                        if (urlMatch) {
                            console.log(`\n   📍 URL: ${urlMatch[1].substring(0, 150)}`);
                        }
                        
                        flowData.requests.push({
                            stage: "post_login",
                            number: afterMajorCounter,
                            method: lines[0],
                            size: len
                        });
                        
                        if (afterMajorCounter === MAX_AFTER_MAJOR) {
                            console.log("\n" + "═".repeat(70));
                            console.log(`✅ CAPTURA COMPLETA! ${MAX_AFTER_MAJOR} APIs após login capturadas.`);
                            console.log("═".repeat(70));
                            saveToFile();
                        }
                    }
                } catch(e) {}
            }
        }
    });
}

// ==================== 7. CAPTURAR RESPOSTAS DAS APIs PÓS-LOGIN ====================
function captureAfterMajorResponses() {
    const sslRead = Module.findExportByName("libssl.so", "SSL_read");
    if (!sslRead) return;
    
    let responseCounter = 0;
    
    Interceptor.attach(sslRead, {
        onEnter: function(args) {
            this.buf = args[1];
            this.len = args[2].toInt32();
        },
        onLeave: function(retval) {
            if (!majorLoginCaptured) return;
            if (responseCounter >= MAX_AFTER_MAJOR) return;
            
            const len = retval.toInt32();
            if (len > 100 && len < 50000) {
                try {
                    const str = this.buf.readCString(Math.min(len, 500));
                    if (str && (str.includes("HTTP/1.1 200") || str.includes("{") || str.includes("["))) {
                        responseCounter++;
                        console.log(`\n📥 RESPOSTA ${responseCounter} (${len} bytes):`);
                        console.log(`   ${str.substring(0, 200)}...`);
                        
                        flowData.responses.push({
                            stage: "post_login_response",
                            number: responseCounter,
                            size: len,
                            preview: str.substring(0, 200)
                        });
                    }
                } catch(e) {}
            }
        }
    });
}

