def generate_timestamp():
    """Gera timestamp no formato esperado"""
    return str(int(time.time() * 1000))

def generate_uid():
    """Gera um UID padrão para guest"""
    return str(random.randint(4000000000, 5000000000))

def generate_password_hash():
    """Gera um hash SHA256 padrão para guest (64 caracteres hex)"""
    import hashlib
    import secrets
    random_string = secrets.token_hex(32)
    return hashlib.sha256(random_string.encode()).hexdigest().upper()

def build_major_payload(access_token, client_version="1.123.10"):
    """Constrói o payload do MajorLogin (baseado no capturado)"""
    
    timestamp = generate_timestamp()
    uid = generate_uid()
    
    payload = DEVICE_DATA.copy()
    payload.update({
        "af_timestamp": timestamp,
        "uid": uid,
        "timepassedsincelastlaunch": "265",
        "prev_session_dur": 265,
        "installDate": datetime.now().strftime("%Y-%m-%d_%H%M%S+0000"),
        "firstLaunchDate": datetime.now().strftime("%Y-%m-%d_%H%M%S-0300"),
        "date1": datetime.now().strftime("%Y-%m-%d_%H%M%S-0300"),
        "date2": datetime.now().strftime("%Y-%m-%d_%H%M%S-0300"),
        "last_boot_time": int(time.time() * 1000),
        "tokenRefreshConfigured": False,
        "client_version": client_version
    })
    
    return json.dumps(payload, separators=(',', ':'))

def encrypt_payload(payload_str):
    """Criptografa o payload com AES-CBC"""
    cipher = AES.new(AES_KEY, AES.MODE_CBC, AES_IV)
    padded = pad(payload_str.encode('utf-8'), AES.block_size)
    encrypted = cipher.encrypt(padded)
    return encrypted

def send_major_login(encrypted_payload):
    """Envia o MajorLogin request"""
    headers = HEADERS_APPSFLYER.copy()
    headers["Content-Length"] = str(len(encrypted_payload))
    
    response = requests.post(
        f"{MAJOR_LOGIN_URL}?app_id=com.dts.freefireth&buildnumber=6.17.3",
        headers=headers,
        data=encrypted_payload
    )
    return response

def decode_jwt(jwt):
    """Decodifica JWT e retorna payload"""
    try:
        parts = jwt.split('.')
        if len(parts) == 3:
            payload = json.loads(base64.b64decode(parts[1] + '==').decode())
            return payload
    except:
        pass
    return None

# ==================== FLUXO PRINCIPAL ====================
class FreeFireLogin:
    def __init__(self, uid=None, password=None):
        self.uid = uid or generate_uid()
        self.password = password or generate_password_hash()
        self.access_token = None
        self.refresh_token = None
        self.jwt = None
        self.account_id = None
    
    def oauth_login(self):
        """Passo 1: Obter OAuth token"""
        print(f"\n🔐 [1/3] Fazendo OAuth login...")
        print(f"   UID: {self.uid}")
        print(f"   Password: {self.password[:32]}...")
        
        payload = {
            "client_id": 100067,
            "client_secret": "2ee44819e9b4598845141067b281621874d0d5d7af9d8f7e00c1e54715b7d1e3",
            "client_type": 2,
            "password": self.password,
            "response_type": "token",
            "uid": self.uid
        }
        
        response = requests.post(OAUTH_URL, json=payload, headers=HEADERS_OAUTH)
        
        if response.status_code != 200:
            print(f"   ❌ OAuth falhou: {response.status_code}")
            print(f"   {response.text}")
            return False
        
        data = response.json()
        self.access_token = data.get('access_token')
        self.refresh_token = data.get('refresh_token')
        
        print(f"   ✅ Access Token: {self.access_token[:50]}...")
        print(f"   ✅ Refresh Token: {self.refresh_token[:50]}...")
        return True
    
    def major_login(self):
        """Passo 2: Enviar MajorLogin (criptografado)"""
        print(f"\n🔐 [2/3] Fazendo MajorLogin...")
        
        payload_str = build_major_payload(self.access_token)
        encrypted = encrypt_payload(payload_str)
        
        print(f"   Payload: {len(payload_str)} bytes")
        print(f"   Criptografado: {len(encrypted)} bytes")
        
        response = send_major_login(encrypted)
        
        if response.status_code != 200:
            print(f"   ❌ MajorLogin falhou: {response.status_code}")
            print(f"   {response.text[:200]}")
            return False
        
        # Tentar extrair JWT da resposta
        try:
            # Resposta pode estar em texto plano
            text = response.text
            if text and 'eyJ' in text:
                import re
                jwt_match = re.search(r'eyJ[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+', text)
                if jwt_match:
                    self.jwt = jwt_match.group()
                    payload = decode_jwt(self.jwt)
                    if payload:
                        self.account_id = payload.get('account_id')
                    print(f"   ✅ JWT obtido!")
                    print(f"   Account ID: {self.account_id}")
                    return True
        except:
            pass
        
        print(f"   ⚠️ Resposta: {response.text[:200]}")
        return True
    
    def run(self):
        """Executa fluxo completo"""
        print("\n" + "="*60)
        print("🚀 FREE FIRE LOGIN FLOW")
        print("="*60)
        
        if not self.oauth_login():
            return None
        
        if not self.major_login():
            return None
        
        print("\n" + "="*60)
        print("✅ LOGIN COMPLETO!")
        print("="*60)
        print(f"📱 Account ID: {self.account_id}")
        print(f"🔑 JWT: {self.jwt[:100]}...")
        
        return {
            "uid": self.uid,
            "password": self.password,
            "access_token": self.access_token,
            "refresh_token": self.refresh_token,
            "account_id": self.account_id,
            "jwt": self.jwt
        }

# ==================== MAIN ====================
