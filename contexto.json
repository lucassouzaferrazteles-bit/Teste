import re
import json
from pathlib import Path

def parse_log(log_path):
    """Extrai JWT do arquivo de log"""
    
    with open(log_path, 'r', encoding='utf-8', errors='ignore') as f:
        content = f.read()
    
    # Procurar JWT
    jwt_match = re.search(r'eyJ[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+', content)
    
    if jwt_match:
        jwt = jwt_match.group()
        print("✅ JWT ENCONTRADO!")
        print(f"\n{jwt}\n")
        
        # Decodificar
        try:
            parts = jwt.split('.')
            payload = json.loads(base64.b64decode(parts[1] + '==').decode())
            print("📦 PAYLOAD:")
            print(json.dumps(payload, indent=2))
            print(f"\n🆔 Account ID: {payload.get('account_id')}")
        except Exception as e:
            print(f"Erro ao decodificar: {e}")
        
        return jwt
    else:
        print("❌ Nenhum JWT encontrado no log")
        print("\n📋 Conteúdo do log:")
        print(content[:2000])
        return None

if __name__ == "__main__":
    import base64
    log_file = Path("jwt_capture_log.txt")
    if log_file.exists():
        parse_log(log_file)
    else:
        print("Arquivo jwt_capture_log.txt não encontrado!")
        print("Execute: adb pull /sdcard/jwt_capture_log.txt")
