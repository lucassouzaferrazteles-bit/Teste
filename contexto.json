        import re
        jwt_match = re.search(r'eyJ[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+', response.text)
        if jwt_match:
            result["jwt"] = jwt_match.group(0)
            # Decodificar payload do JWT
            try:
                payload = jwt_match.group(0).split('.')[1]
                payload += '=' * (4 - len(payload) % 4)
                decoded = json.loads(base64.b64decode(payload))
                result["account_id"] = decoded.get("account_id")
                result["nickname"] = decoded.get("nickname")
            except:
                pass
    
    return result

