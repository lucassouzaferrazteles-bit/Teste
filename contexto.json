3️⃣ Script para extrair informações do dump.cs (o arquivo REAL)
powershell
# Save as: Extract-From-RealDump.ps1
# Execute na PASTA onde está o dump.cs REAL

param(
    [string]$DumpPath = "."
)

Write-Host "========================================" -ForegroundColor Cyan
Write-Host "EXTRAINDO INFORMAÇÕES DO DUMP.CS REAL" -ForegroundColor Cyan
Write-Host "========================================" -ForegroundColor Cyan

# Encontrar o dump.cs
$dumpFile = Get-ChildItem -Path $DumpPath -Recurse -Filter "dump.cs" | Select-Object -First 1

if (-not $dumpFile) {
    Write-Host "❌ dump.cs não encontrado!" -ForegroundColor Red
    Write-Host "Certifique-se de que você está na pasta correta." -ForegroundColor Yellow
    exit
}

Write-Host "✅ dump.cs encontrado em: $($dumpFile.FullName)" -ForegroundColor Green

$outputFile = "RealLoginInfo.txt"
$results = @()

# Buscar pela classe COW_UIModelLogin
Write-Host "`n🔍 Buscando COW_UIModelLogin..." -ForegroundColor Yellow
$loginClass = Select-String -Path $dumpFile.FullName -Pattern "class COW_UIModelLogin" -Context 0,200
if ($loginClass) {
    $results += "=== COW_UIModelLogin ==="
    $results += $loginClass.Line
    $results += $loginClass.Context.PostContext
    $results += ""
}

# Buscar pelo método Login
Write-Host "🔍 Buscando métodos de login..." -ForegroundColor Yellow
$loginMethods = Select-String -Path $dumpFile.FullName -Pattern "public.*Login\s*\(" -Context 2,10
if ($loginMethods) {
    $results += "=== MÉTODOS DE LOGIN ==="
    foreach ($method in $loginMethods) {
        $results += "Linha $($method.LineNumber): $($method.Line)"
        $results += $method.Context.PostContext
    }
    $results += ""
}

# Buscar pela estrutura tcp_SecPlayerLoginReq
Write-Host "🔍 Buscando tcp_SecPlayerLoginReq..." -ForegroundColor Yellow
$secLoginReq = Select-String -Path $dumpFile.FullName -Pattern "tcp_SecPlayerLoginReq" -Context 5,20
if ($secLoginReq) {
    $results += "=== TCP_SECPLAYERLOGINREQ ==="
    foreach ($line in $secLoginReq) {
        $results += "Linha $($line.LineNumber): $($line.Line)"
        $results += $line.Context.PostContext
    }
    $results += ""
}

# Buscar por Garena MSDK
Write-Host "🔍 Buscando Garena MSDK..." -ForegroundColor Yellow
$garena = Select-String -Path $dumpFile.FullName -Pattern "Garena|MSDK" -Context 2,10
if ($garena) {
    $results += "=== GARENA/MSDK ==="
    foreach ($item in $garena | Select-Object -First 20) {
        $results += "Linha $($item.LineNumber): $($item.Line)"
    }
    $results += ""
}

# Buscar offsets de funções
Write-Host "🔍 Buscando offsets (RVAs)..." -ForegroundColor Yellow
$offsets = Select-String -Path $dumpFile.FullName -Pattern "RVA: 0x[0-9A-F]+" | Select-Object -First 50
if ($offsets) {
    $results += "=== OFFSETS ENCONTRADOS (primeiros 50) ==="
    foreach ($offset in $offsets) {
        $results += "Linha $($offset.LineNumber): $($offset.Line)"
    }
    $results += ""
}

# Salvar resultados
$outputPath = Join-Path $DumpPath $outputFile
$results | Out-File -FilePath $outputPath -Encoding UTF8

Write-Host "`n========================================" -ForegroundColor Green
Write-Host "✅ Extração concluída!" -ForegroundColor Green
Write-Host "📄 Resultados salvos em: $outputPath" -ForegroundColor Yellow
Write-Host "========================================" -ForegroundColor Green

# Abrir o arquivo
if (Test-Path $outputPath) {
    Start-Process notepad.exe $outputPath
}
4️⃣ Se você tem o arquivo il2cpp.h (com offsets reais)
powershell
# Script para extrair offsets específicos do il2cpp.h
param([string]$Path = ".")

$il2cppFile = Get-ChildItem -Path $Path -Recurse -Filter "il2cpp.h" | Select-Object -First 1

if ($il2cppFile) {
    Write-Host "✅ il2cpp.h encontrado!" -ForegroundColor Green
    
    $offsets = @()
    $offsets += "=== OFFSETS DO IL2CPP.H ==="
    
    # Buscar padrões de offset
    $lines = Get-Content $il2cppFile.FullName
    foreach ($line in $lines) {
        if ($line -match "0x[0-9A-Fa-f]{8}" -and $line -match "Login|Model|SDK|Garena") {
            $offsets += $line.Trim()
        }
    }
    
    $offsets | Out-File -FilePath "IL2CPP_Offsets.txt" -Encoding UTF8
    Write-Host "Offsets salvos em IL2CPP_Offsets.txt" -ForegroundColor Green
} else {
    Write-Host "❌ il2cpp.h não encontrado!" -ForegroundColor Red
}
