Excelente! O script capturou informações valiosas, mas notei que o JWT do MajorLogin não apareceu no log porque a resposta pode estar em formato binário (protobuf) e não como texto plano. Vamos ajustar o script para capturar o JWT mesmo que esteja em formato binário.

🔧 Script Ajustado para Capturar JWT em Formato Binário
javascript
// save as: FullFlow_v2.js
// frida -U "Free Fire" -l FullFlow_v2.js

console.log("\n╔════════════════════════════════════════════════════════════╗");
console.log("║     FREE FIRE - COMPLETE FLOW CAPTURE v3                   ║");
console.log("║     Com captura de JWT em formato binário                  ║");
console.log("╚════════════════════════════════════════════════════════════╝\n");

let flowData = {
    startTime: Date.now(),
    credentials: null,
    oauth_response: null,
    major_login_request: null,
    major_login_response: null,
    jwt: null,
    account_id: null,
    requests: [],
    responses: []
};

let afterMajorCounter = 0;
let majorLoginCaptured = false;
const MAX_AFTER_MAJOR = 10;

function cleanJWT(str) {
    const match = str.match(/eyJ[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+/);
    return match ? match[0] : null;
}

function bytesToHex(bytes) {
    if (!bytes) return "";
    return Array.from(new Uint8Array(bytes)).map(b => b.toString(16).padStart(2, '0')).join(' ');
}

function extractJWTFromRawData(data) {
    // Procura por padrão JWT em dados binários
    for (let i = 0; i < data.length - 20; i++) {
        if (data[i] === 0x65 && data[i+1] === 0x79 && data[i+2] === 0x4A) { // "eyJ"
            let jwt = "";
            for (let j = i; j < data.length && data[j] !== 0x00 && j < i + 500; j++) {
                jwt += String.fromCharCode(data[j]);
            }
            if (jwt.length > 50 && jwt.split('.').length === 3) {
                return jwt;
            }
        }
    }
    return null;
}

function printSeparator(title) {
    console.log("\n" + "═".repeat(70));
    console.log(`📌 ${title}`);
    console.log("═".repeat(70));
}

// ==================== 1. CAPTURAR OAUTH GRANT ====================
function captureOAuth() {
    const sslWrite = Module.findExportByName("libssl.so", "SSL_write");
    Interceptor.attach(sslWrite, {
        onEnter: function(args) {
            const buf = args[1];
            const len = args[2].toInt32();
            if (len > 200 && len < 800) {
                try {
                    const str = buf.readCString(len);
                    if (str && str.includes("oauth/guest/token:grant")) {
                        printSeparator(`OAUTH GRANT REQUEST`);
                        const jsonMatch = str.match(/\{.*\}/s);
                        if (jsonMatch) {
                            const json = JSON.parse(jsonMatch[0]);
                            console.log(`   📱 UID: ${json.uid}`);
                            console.log(`   🔑 Password: ${json.password.substring(0, 32)}...`);
                            flowData.credentials = { uid: json.uid, password: json.password };
                        }
                    }
                } catch(e) {}
            }
        }
    });
}

// ==================== 2. CAPTURAR RESPOSTA DO OAUTH ====================
function captureOAuthResponse() {
    const sslRead = Module.findExportByName("libssl.so", "SSL_read");
    Interceptor.attach(sslRead, {
        onEnter: function(args) { this.buf = args[1]; },
        onLeave: function(retval) {
            const len = retval.toInt32();
            if (len > 100 && len < 5000) {
                try {
                    const str = this.buf.readCString(len);
                    if (str && str.includes("access_token")) {
                        printSeparator(`OAUTH GRANT RESPONSE`);
                        const json = JSON.parse(str);
                        console.log(`   ✅ Access Token: ${json.access_token?.substring(0, 50)}...`);
                        console.log(`   🔄 Refresh Token: ${json.refresh_token?.substring(0, 50)}...`);
                        console.log(`   📧 Open ID: ${json.open_id}`);
                        flowData.oauth_response = json;
                    }
                } catch(e) {}
            }
        }
    });
}

// ==================== 3. CAPTURAR MAJOR LOGIN REQUEST ====================
function captureMajorLoginRequest() {
    const sslWrite = Module.findExportByName("libssl.so", "SSL_write");
    Interceptor.attach(sslWrite, {
        onEnter: function(args) {
            const buf = args[1];
            const len = args[2].toInt32();
            if (len > 1700 && len < 3000) {
                try {
                    const str = buf.readCString(Math.min(len, 200));
                    if (str && str.includes("androidevent")) {
                        majorLoginCaptured = true;
                        printSeparator(`MAJOR LOGIN REQUEST (${len} bytes)`);
                        
                        // Capturar payload bruto
                        const bodyStart = str.indexOf('\r\n\r\n');
                        if (bodyStart > 0) {
                            const payload = buf.add(bodyStart + 4).readByteArray(len - bodyStart - 4);
                            if (payload) {
                                console.log(`\n🔐 PAYLOAD CRIPTOGRAFADO (${payload.byteLength} bytes):`);
                                console.log(`   ${bytesToHex(payload).substring(0, 200)}...`);
                                flowData.major_login_request = { size: len, payload_hex: bytesToHex(payload).substring(0, 500) };
                            }
                        }
                    }
                } catch(e) {}
            }
        }
    });
}

// ==================== 4. CAPTURAR MAJOR LOGIN RESPONSE (JWT) ====================
function captureMajorLoginResponse() {
    const sslRead = Module.findExportByName("libssl.so", "SSL_read");
    Interceptor.attach(sslRead, {
        onEnter: function(args) { this.buf = args[1]; this.buffer = null; },
        onLeave: function(retval) {
            const len = retval.toInt32();
            if (len > 500 && len < 20000) {
                try {
                    // Tentar como texto primeiro
                    const str = this.buf.readCString(len);
                    const jwt = cleanJWT(str);
                    if (jwt) {
                        printSeparator(`MAJOR LOGIN RESPONSE - JWT ENCONTRADO!`);
                        console.log(`\n🎫 ${jwt}\n`);
                        flowData.jwt = jwt;
                        decodeJWT(jwt);
                    } else {
                        // Se não achou JWT em texto, procurar nos bytes brutos
                        const rawBytes = this.buf.readByteArray(len);
                        const jwtFromBytes = extractJWTFromRawData(new Uint8Array(rawBytes));
                        if (jwtFromBytes) {
                            printSeparator(`MAJOR LOGIN RESPONSE - JWT EM BYTES!`);
                            console.log(`\n🎫 ${jwtFromBytes}\n`);
                            flowData.jwt = jwtFromBytes;
                            decodeJWT(jwtFromBytes);
                        } else {
                            console.log(`\n📥 RESPOSTA MAJOR LOGIN (${len} bytes) - FORMATO BINÁRIO:`);
                            console.log(`   ${bytesToHex(rawBytes).substring(0, 200)}...`);
                            flowData.major_login_response = { size: len, hex: bytesToHex(rawBytes).substring(0, 500) };
                        }
                    }
                } catch(e) {}
            }
        }
    });
}

function decodeJWT(jwt) {
    try {
        const parts = jwt.split('.');
        const payload = JSON.parse(Buffer.from(parts[1], 'base64').toString());
        console.log("\n📦 JWT PAYLOAD:");
        console.log(JSON.stringify(payload, null, 2));
        flowData.account_id = payload.account_id;
        console.log(`\n🆔 ACCOUNT ID: ${payload.account_id}`);
    } catch(e) {}
}

// ==================== 5. CAPTURAR PRÓXIMAS 10 APIs ====================
function captureAfterMajorLogin() {
    const sslWrite = Module.findExportByName("libssl.so", "SSL_write");
    Interceptor.attach(sslWrite, {
        onEnter: function(args) {
            if (!majorLoginCaptured) return;
            if (afterMajorCounter >= MAX_AFTER_MAJOR) return;
            
            const buf = args[1];
            const len = args[2].toInt32();
            if (len > 100 && len < 10000) {
                try {
                    const str = buf.readCString(Math.min(len, 500));
                    if (str && (str.includes("GET") || str.includes("POST"))) {
                        if (str.includes("androidevent") || str.includes("appsflyer")) return;
                        
                        afterMajorCounter++;
                        printSeparator(`[${afterMajorCounter}/${MAX_AFTER_MAJOR}] API APÓS LOGIN`);
                        
                        const lines = str.split('\n');
                        console.log(`   ${lines[0]}`);
                        
                        // Extrair token se presente
                        const tokenMatch = str.match(/access_token=([a-f0-9]+)/);
                        if (tokenMatch) {
                            console.log(`   🔑 Access Token: ${tokenMatch[1].substring(0, 40)}...`);
                        }
                        
                        flowData.requests.push({ number: afterMajorCounter, method: lines[0], size: len });
                        
                        if (afterMajorCounter === MAX_AFTER_MAJOR) {
                            console.log("\n" + "═".repeat(70));
                            console.log(`✅ CAPTURA COMPLETA!`);
                            console.log("═".repeat(70));
                            printSummary();
                        }
                    }
                } catch(e) {}
            }
        }
    });
}

function printSummary() {
    console.log("\n📊 RESUMO DO FLUXO:");
    console.log(`   🆔 Account ID: ${flowData.account_id || "N/A"}`);
    console.log(`   🔑 JWT: ${flowData.jwt ? flowData.jwt.substring(0, 80) + "..." : "N/A"}`);
    console.log(`   📋 Credenciais: ${flowData.credentials ? `${flowData.credentials.uid}` : "N/A"}`);
}

// ==================== INICIAR ====================
function start() {
    console.log("[*] Iniciando hooks...\n");
    captureOAuth();
