// ==================== FUNÇÃO SIMPLES PARA EXTRAIR JWT ====================
function extractJWT(str) {
    if (!str) return null;
    // Busca padrão JWT: eyJ... (começa com eyJ e tem 2 pontos)
    const match = str.match(/eyJ[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+/);
    return match ? match[0] : null;
}

// ==================== 1. HOOK SSL_READ (APENAS PARA RESPOSTAS) ====================
const sslRead = Module.findExportByName("libssl.so", "SSL_read");
if (sslRead) {
    Interceptor.attach(sslRead, {
        onEnter: function(args) {
            this.buf = args[1];
            this.len = args[2].toInt32();
        },
        onLeave: function(retval) {
            if (found) return;
            const len = retval.toInt32();
            if (len > 200 && len < 10000) {
                try {
                    // Tentar ler como string (máximo 1000 chars)
                    const str = this.buf.readCString(Math.min(len, 1000));
                    const jwt = extractJWT(str);
                    if (jwt) {
                        found = true;
