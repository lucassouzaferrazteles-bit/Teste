# save as: extract_proto_from_dump.py
# Coloque na mesma pasta do dump.cs e execute

import re
import json
from pathlib import Path

def extract_class_from_dump(dump_path, class_name):
    """Extrai uma classe específica do dump.cs"""
    
    with open(dump_path, 'r', encoding='utf-8', errors='ignore') as f:
        content = f.read()
    
    # Procurar pela classe
    pattern = rf'public class {class_name}[^{{]*\{{[^{{}}]*\}}'
    matches = re.findall(pattern, content, re.DOTALL)
    
    if matches:
        print(f"\n=== {class_name} ===\n")
        print(matches[0][:2000])
        return matches[0]
    return None

def extract_fields(dump_path, struct_name):
    """Extrai os campos de uma struct"""
    
    with open(dump_path, 'r', encoding='utf-8', errors='ignore') as f:
        content = f.read()
    
    # Procurar pela struct
    pattern = rf'struct {struct_name}[^{{]*\{{([^{{}}]*)\}}'
    match = re.search(pattern, content, re.DOTALL)
    
    if match:
        fields_text = match.group(1)
        fields = []
        for line in fields_text.split('\n'):
            line = line.strip()
            if line and not line.startswith('//'):
                # Extrair tipo e nome
                parts = line.split()
                if len(parts) >= 2:
                    field_type = ' '.join(parts[:-1])
                    field_name = parts[-1].replace(';', '')
                    fields.append({
                        'type': field_type,
                        'name': field_name,
                        'line': line
                    })
        return fields
    return []

def main():
    # Encontrar dump.cs
    dump_path = Path('dump.cs')
    if not dump_path.exists():
        print("❌ dump.cs não encontrado na pasta atual!")
        return
    
    print("╔════════════════════════════════════════════════════════════╗")
    print("║     EXTRAINDO PROTOBUF DO DUMP.CS                          ║")
    print("╚════════════════════════════════════════════════════════════╝")
    
    # 1. Extrair tcp_SecPlayerLoginReq
    print("\n📦 [1] tcp_SecPlayerLoginReq_Fields")
    print("-" * 50)
    fields = extract_fields(dump_path, 'tcp_SecPlayerLoginReq_Fields')
    for f in fields:
        print(f"   {f['line']}")
    
    # 2. Extrair proto_MajorLoginRes_Fields
    print("\n📦 [2] proto_MajorLoginRes_Fields")
    print("-" * 50)
    fields = extract_fields(dump_path, 'proto_MajorLoginRes_Fields')
    for f in fields:
        print(f"   {f['line']}")
    
    # 3. Buscar por string "token" (onde está o JWT)
    print("\n🔑 [3] Buscando referências a 'token'")
    print("-" * 50)
    with open(dump_path, 'r', encoding='utf-8', errors='ignore') as f:
        for i, line in enumerate(f):
            if 'token' in line.lower() and ('string' in line or 'Token' in line):
                print(f"   Linha {i}: {line.strip()[:100]}")
    
    # 4. Salvar resultados
    output = {
        "tcp_SecPlayerLoginReq_fields": extract_fields(dump_path, 'tcp_SecPlayerLoginReq_Fields'),
        "proto_MajorLoginRes_fields": extract_fields(dump_path, 'proto_MajorLoginRes_Fields')
    }
    
    with open('proto_fields.json', 'w') as f:
        json.dump(output, f, indent=2)
    
    print("\n💾 Resultados salvos em proto_fields.json")

if __name__ == "__main__":
    main()
