import re
from pathlib import Path

def search_pattern(dump_content, pattern, context_lines=3):
    """Busca um padrão no dump e mostra contexto"""
    lines = dump_content.split('\n')
    results = []
    
    for i, line in enumerate(lines):
        if re.search(pattern, line, re.IGNORECASE):
            start = max(0, i - context_lines)
            end = min(len(lines), i + context_lines + 1)
            context = '\n'.join(lines[start:end])
            results.append({
                'line_num': i,
                'line': line,
                'context': context
            })
    return results

def main():
    dump_path = Path('dump.cs')
    if not dump_path.exists():
        print("❌ dump.cs não encontrado!")
        return
    
    print("╔════════════════════════════════════════════════════════════╗")
    print("║     BUSCANDO ESTRUTURAS NO DUMP.CS                         ║")
    print("╚════════════════════════════════════════════════════════════╝")
    
    with open(dump_path, 'r', encoding='utf-8', errors='ignore') as f:
        content = f.read()
    
    # Padrões de busca
    patterns = [
        ("SecPlayerLogin", r'SecPlayerLogin'),
        ("MajorLoginRes", r'MajorLoginRes'),
        ("tcp_.*Login", r'tcp_\w*Login'),
        ("proto_.*Login", r'proto_\w*Login'),
        ("COW_UIModelLogin", r'COW_UIModelLogin'),
        ("GarenaMSDKMgr", r'GarenaMSDKMgr'),
    ]
    
    for name, pattern in patterns:
        print(f"\n{'='*60}")
        print(f"🔍 Buscando: {name}")
        print('='*60)
        
        results = search_pattern(content, pattern, context_lines=2)
        
        if results:
            print(f"✅ Encontrado {len(results)} ocorrência(s):\n")
            for r in results[:10]:  # Mostrar até 10
                print(f"   Linha {r['line_num']}: {r['line'][:150]}")
        else:
            print(f"❌ Nenhuma ocorrência encontrada")
    
    # Busca específica por structs
    print(f"\n{'='*60}")
    print("🔍 Buscando structs com 'Fields'")
    print('='*60)
    
    struct_pattern = r'struct \w*Fields\s*\{'
    matches = re.findall(struct_pattern, content)
    print(f"Total de structs *Fields encontradas: {len(matches)}")
    
    # Mostrar primeiras 20
    for i, m in enumerate(matches[:20]):
        print(f"   {i+1}. {m}")

if __name__ == "__main__":
    main()
