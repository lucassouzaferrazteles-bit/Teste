# save as: extract_from_il2cpp.py
# python extract_from_il2cpp.py

import re
from pathlib import Path

def extract_struct_fields(content, struct_name):
    """Extrai os campos de uma struct do il2cpp.h"""
    pattern = rf'struct {struct_name} \{{\s*([^}}]*)\}}'
    match = re.search(pattern, content, re.DOTALL)
    
    if match:
        fields_text = match.group(1)
        fields = []
        for line in fields_text.split('\n'):
            line = line.strip()
            if line and not line.startswith('//'):
                # Remove ponto e vírgula
                line = line.rstrip(';')
                if line:
                    parts = line.split()
                    if len(parts) >= 2:
                        field_type = ' '.join(parts[:-1])
                        field_name = parts[-1]
                        fields.append({
                            'type': field_type,
                            'name': field_name,
                            'line': line
                        })
        return fields
    return None

def main():
    il2cpp_path = Path('il2cpp.h')
    if not il2cpp_path.exists():
        print("❌ il2cpp.h não encontrado!")
        return
    
    print("╔════════════════════════════════════════════════════════════╗")
    print("║     EXTRAINDO ESTRUTURAS DO IL2CPP.H                       ║")
    print("╚════════════════════════════════════════════════════════════╝")
    
    with open(il2cpp_path, 'r', encoding='utf-8', errors='ignore') as f:
        content = f.read()
    
    # Estruturas para extrair
    structs = [
        'tcp_SecPlayerLoginReq_Fields',
        'proto_MajorLoginRes_Fields',
        'tcp_SecPlayerLoginReq_o',
        'proto_MajorLoginRes_o'
    ]
    
    results = {}
    
    for struct_name in structs:
        print(f"\n{'='*60}")
        print(f"📦 {struct_name}")
        print('='*60)
        
        fields = extract_struct_fields(content, struct_name)
        if fields:
            print(f"Campos encontrados ({len(fields)}):")
            for f in fields:
                print(f"   • {f['name']}: {f['type']}")
            results[struct_name] = fields
        else:
            print("❌ Não encontrado")
    
    # Gerar payload Python baseado nas estruturas
    print(f"\n{'='*60}")
    print("🔧 PAYLOAD PARA REPLICAÇÃO")
    print('='*60)
    
    sec_fields = results.get('tcp_SecPlayerLoginReq_Fields', [])
    if sec_fields:
        print("\n# tcp_SecPlayerLoginReq (para enviar no MajorLogin)")
        print("payload = {")
        for f in sec_fields:
            if f['type'] == 'uint32_t':
                print(f"    '{f['name']}': 0,  # uint32")
            elif 'String' in f['type']:
                print(f"    '{f['name']}': '',  # string")
        print("}")
    
    major_fields = results.get('proto_MajorLoginRes_Fields', [])
    if major_fields:
        print("\n# proto_MajorLoginRes (resposta - contém o JWT)")
        for f in major_fields:
            if 'token' in f['name'].lower() or 'account' in f['name'].lower():
                print(f"🔑 Campo mais importante: {f['name']} ({f['type']})")
    
    # Salvar resultados
    import json
    with open('il2cpp_structs.json', 'w') as f:
        json.dumps(results, indent=2)
    
    print(f"\n💾 Resultados salvos em il2cpp_structs.json")

if __name__ == "__main__":
    main()
