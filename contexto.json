import requests
import json
import base64
import struct
import time
import random
from Crypto.Cipher import AES
from Crypto.Util.Padding import pad, unpad

# ============================================================================
# CONSTANTES CAPTURADAS
# ============================================================================
UID = "4765511949"
PASSWORD = "EC7424E285BA6496A73CD5668DF93F04539FFE3611C5DC0A5E588247B1BFB21C"

# Chaves AES do libcrypto.so
AES_KEY = bytes.fromhex("4fb533b136ef44780fb374721624ba58")
AES_IV = bytes.fromhex("c6cfe71ef171a1334fc8d31506af7065")

# OAuth
CLIENT_ID = 100067
CLIENT_SECRET = "2ee44819e9b4598845141067b281621874d0d5d7af9d8f7e00c1e54715b7d1e3"

# Headers
HEADERS_OAUTH = {
    "User-Agent": "GarenaMSDK/4.0.41(M2006C3LG ;Android 11;pt;BR;app 1.123.1 2019120270;)",
    "Accept": "application/json",
    "Content-Type": "application/json; charset=utf-8",
}

HEADERS_MAJOR = {
    "User-Agent": "Dalvik/2.1.0 (Linux; U; Android 11; M2006C3LG Build/RP1A.200720.011)",
    "Content-Type": "application/octet-stream",
}

# ============================================================================
# FUNÇÕES
# ============================================================================
def encrypt_payload(data: bytes) -> bytes:
    """Criptografa com AES-CBC (MAIN_KEY + MAIN_IV)"""
    cipher = AES.new(AES_KEY, AES.MODE_CBC, AES_IV)
    padded = pad(data, AES.block_size)
    return cipher.encrypt(padded)

def decrypt_response(encrypted: bytes) -> bytes:
    """Descriptografa resposta do MajorLogin"""
    cipher = AES.new(AES_KEY, AES.MODE_CBC, AES_IV)
    decrypted = cipher.decrypt(encrypted)
    return unpad(decrypted, AES.block_size)

def build_sec_player_login_req(access_token: str) -> bytes:
    """
    Constrói o payload baseado na estrutura tcp_SecPlayerLoginReq_Fields
    Usa JSON (alternativa ao protobuf)
    """
    payload = {
        "area_id": 1,
        "client_version_code": "6.17.3",
        "client_architecture": 2,
        "is_new_client": 1,
        "is_reconnect": 0,
        "access_token": access_token,
        "uid": UID,
        "timestamp": int(time.time() * 1000)
    }
    return json.dumps(payload, separators=(',', ':')).encode('utf-8')

def extract_jwt_from_response(response_data: bytes) -> tuple:
    """Extrai JWT e Account ID da resposta"""
    try:
        # Tentar como JSON primeiro
        text = response_data.decode('utf-8', errors='ignore')
        import re
        jwt_match = re.search(r'eyJ[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+', text)
        if jwt_match:
            jwt = jwt_match.group()
            parts = jwt.split('.')
            payload = json.loads(base64.b64decode(parts[1] + '==').decode())
            return jwt, payload.get('account_id')
    except:
        pass
    
    # Se não encontrou, retornar None
    return None, None

# ============================================================================
# PASSOS DO LOGIN
# ============================================================================
def oauth_grant():
    """Passo 1: OAuth Guest Grant"""
    url = "https://100067.connect.garena.com/api/v2/oauth/guest/token:grant"
    
    payload = {
        "client_id": CLIENT_ID,
        "client_secret": CLIENT_SECRET,
        "client_type": 2,
        "password": PASSWORD,
        "response_type": "token",
        "uid": UID
    }
    
    print(f"\n🔐 [1/2] OAuth Grant")
    print(f"   UID: {UID}")
    
    response = requests.post(url, json=payload, headers=HEADERS_OAUTH, timeout=30)
    
    if response.status_code != 200:
        raise Exception(f"OAuth falhou: {response.status_code} - {response.text[:200]}")
    
    data = response.json()
    access_token = data.get('access_token')
    print(f"   ✅ Access Token: {access_token[:50]}...")
    
    return access_token

def major_login(access_token: str):
    """Passo 2: MajorLogin - obter JWT"""
    url = "https://rslw0r.launches.appsflyersdk.com/api/v6.17/androidevent?app_id=com.dts.freefireth&buildnumber=6.17.3"
    
    # Construir e criptografar payload
    plain_payload = build_sec_player_login_req(access_token)
    encrypted_payload = encrypt_payload(plain_payload)
    
    print(f"\n🔐 [2/2] MajorLogin")
    print(f"   Payload plano: {len(plain_payload)} bytes")
    print(f"   Payload criptografado: {len(encrypted_payload)} bytes")
    
    response = requests.post(url, headers=HEADERS_MAJOR, data=encrypted_payload, timeout=30)
    
    print(f"   Status: {response.status_code}")
    
    if response.status_code == 200:
        # Tentar descriptografar resposta
        try:
            decrypted = decrypt_response(response.content)
            print(f"   Resposta descriptografada: {len(decrypted)} bytes")
            
            jwt, account_id = extract_jwt_from_response(decrypted)
            if jwt:
                return jwt, account_id
        except Exception as e:
            print(f"   Erro na descriptografia: {e}")
            
        # Ver resposta bruta
        print(f"   Resposta bruta (hex): {response.content[:50].hex()}...")
    
    return None, None

# ============================================================================
# MAIN
# ============================================================================
def main():
    print("╔════════════════════════════════════════════════════════════╗")
    print("║     FREE FIRE - LOGIN FLOW (Baseado no il2cpp.h)          ║")
    print("╚════════════════════════════════════════════════════════════╝")
    
    try:
        # Passo 1
        access_token = oauth_grant()
        
        # Passo 2
        jwt, account_id = major_login(access_token)
        
        if jwt:
            print("\n" + "="*60)
            print("✅ LOGIN COMPLETO!")
            print("="*60)
            print(f"🆔 Account ID: {account_id}")
            print(f"🔑 JWT: {jwt[:100]}...")
            print(f"\n📋 JWT Completo:\n{jwt}")
        else:
            print("\n❌ Não foi possível obter o JWT")
            print("   Verifique se as credenciais ainda são válidas")
            
    except Exception as e:
        print(f"\n❌ Erro: {e}")

if __name__ == "__main__":
    main()
