💻 Código C++ para Replicar Login (Injeção)
cpp
#include <string>
#include <cstring>

// Estruturas necessárias (já definidas no il2cpp.h)
typedef struct {
    void* klass;
    void* monitor;
    struct {
        uint32_t area_id;
        void* client_version_code;  // System_String_o*
        uint32_t client_architecture;
        uint32_t is_new_client;
        uint32_t is_reconnect;
    } fields;
} tcp_SecPlayerLoginReq_o;

typedef struct {
    void* klass;
    void* monitor;
    struct {
        uint64_t account_id;
        void* token;                 // System_String_o*
        void* server_url;            // System_String_o*
        uint32_t ttl;
        void* queue_info;            // proto_LoginQueueInfo_o*
        // ... outros campos omitidos
    } fields;
} proto_MajorLoginRes_o;

// Função para criar uma string no formato Unity/IL2CPP
void* CreateIl2CppString(const std::string& str) {
    typedef void* (*StringCtor)(void*, const char*);
    static StringCtor string_ctor = (StringCtor)0x12345678;  // Ajuste para o offset correto
    return string_ctor(nullptr, str.c_str());
}

// Função para criar uma requisição de login
tcp_SecPlayerLoginReq_o* CreateLoginRequest(
    uint32_t area_id,
    const std::string& client_version,
    uint32_t architecture,
    bool is_new_client,
    bool is_reconnect
) {
    typedef tcp_SecPlayerLoginReq_o* (*CreateReq)();
    static CreateReq create_req = (CreateReq)0x87654321;  // Ajuste para o offset correto
    
    tcp_SecPlayerLoginReq_o* req = create_req();
    if (!req) return nullptr;
    
    req->fields.area_id = area_id;
    req->fields.client_version_code = CreateIl2CppString(client_version);
    req->fields.client_architecture = architecture;
    req->fields.is_new_client = is_new_client ? 1 : 0;
    req->fields.is_reconnect = is_reconnect ? 1 : 0;
    
    return req;
}

// Função principal de login (chama o método do modelo)
bool PerformLogin(COW_UIModelLogin_o* model, const std::string& username, const std::string& password) {
    typedef void (*LoginFunc)(COW_UIModelLogin_o*, const char*, const char*);
    static LoginFunc login_func = (LoginFunc)0xA1B2C3D4;  // Ajuste para o offset correto
    
    if (!model) {
        // Obter a instância singleton do modelo
        typedef COW_UIModelLogin_o* (*GetInstance)();
        static GetInstance get_instance = (GetInstance)0xDEADBEEF;  // Ajuste
        model = get_instance();
        if (!model) return false;
    }
    
    login_func(model, username.c_str(), password.c_str());
    return true;
}

// Callback para processar resposta de login
typedef void (*LoginCallback)(proto_MajorLoginRes_o* response, void* user_data);

void ProcessLoginResponse(proto_MajorLoginRes_o* response) {
    if (!response) {
        printf("Login falhou: resposta nula\n");
        return;
    }
    
    uint64_t account_id = response->fields.account_id;
    char* token = (char*)response->fields.token + sizeof(void*);  // Acessar string real
    char* server_url = (char*)response->fields.server_url + sizeof(void*);
    
    printf("Login bem-sucedido!\n");
    printf("Account ID: %llu\n", account_id);
    printf("Token: %s\n", token);
    printf("Server URL: %s\n", server_url);
    
    // Salvar token para uso futuro
    // SaveAuthToken(token, account_id);
}

// Exemplo de uso completo
void ExampleLoginFlow() {
    // 1. Criar requisição de login seguro
    tcp_SecPlayerLoginReq_o* req = CreateLoginRequest(
        1,                      // area_id (Brasil = 1, ajuste conforme região)
        "1.23.45.678",          // client_version_code
        2,                      // architecture (2 = arm64, 1 = armv7, 3 = x86)
        true,                   // is_new_client (primeiro login)
        false                   // is_reconnect
    );
    
    // 2. Executar login (isso vai disparar a requisição e o callback)
    COW_UIModelLogin_o* model = nullptr;  // Será obtido via singleton
    PerformLogin(model, "usuario_aqui", "senha_aqui");
    
    // Nota: O jogo provavelmente usa callbacks assíncronos.
    // Você precisa fazer hook na função de resposta ou implementar um listener.
}
