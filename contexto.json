// ==================== 4. CAPTURAR MAJOR LOGIN RESPONSE (JWT) ====================
function captureMajorLoginResponse() {
    const sslRead = Module.findExportByName("libssl.so", "SSL_read");
    if (!sslRead) return;
    
    Interceptor.attach(sslRead, {
        onEnter: function(args) {
            this.buf = args[1];
            this.len = args[2].toInt32();
        },
        onLeave: function(retval) {
            const len = retval.toInt32();
            if (len > 500 && len < 10000) {
                try {
                    const str = this.buf.readCString(len);
                    if (str) {
                        const jwt = cleanJWT(str);
                        if (jwt) {
                            console.log("\n═══════════════════════════════════════════════════════════════");
                            console.log("🎫 [2] MAJOR LOGIN RESPONSE - JWT CAPTURADO!");
                            console.log("═══════════════════════════════════════════════════════════════");
                            console.log(`   ${jwt}\n`);
                            flowData.jwt = jwt;
                            flowData.responses.push({ type: "major_login", jwt: jwt });
                            
                            // Decodificar payload
                            try {
                                const parts = jwt.split('.');
                                const payload = JSON.parse(Buffer.from(parts[1], 'base64').toString());
                                console.log("📦 JWT PAYLOAD:");
                                console.log(JSON.stringify(payload, null, 2));
                                flowData.account_id = payload.account_id;
                            } catch(e) {}
                        }
                    }
                } catch(e) {}
            }
        }
    });
}

// ==================== 5. CAPTURAR APIS DO JOGO PÓS-LOGIN ====================
function captureGameAPIs() {
    const sslWrite = Module.findExportByName("libssl.so", "SSL_write");
    if (!sslWrite) return;
    
    let requestCount = 0;
    
    Interceptor.attach(sslWrite, {
        onEnter: function(args) {
            const buf = args[1];
            const len = args[2].toInt32();
            
            if (len > 100 && len < 5000) {
                try {
                    const str = buf.readCString(Math.min(len, 500));
                    if (str && (str.includes("GET") || str.includes("POST")) && !str.includes("androidevent")) {
                        requestCount++;
                        if (requestCount <= 10) {  // Capturar até 10 requisições após login
                            console.log("\n═══════════════════════════════════════════════════════════════");
                            console.log(`🌐 [${requestCount + 2}] GAME API REQUEST`);
                            console.log("═══════════════════════════════════════════════════════════════");
                            
                            const lines = str.split('\n');
                            console.log(`   ${lines[0]}`);
                            
                            for (let line of lines.slice(1, 8)) {
                                if (line.includes("User-Agent") || line.includes("Authorization") || 
                                    line.includes("Content-Type") || line.includes("Host")) {
                                    console.log(`   ${line.trim()}`);
                                }
                            }
                            
                            flowData.requests.push({ type: "game_api", request: lines[0], size: len });
                        }
                    }
                } catch(e) {}
            }
        }
    });
}

// ==================== 6. CAPTURAR RESPOSTAS DAS APIS ====================
function captureGameAPIResponses() {
    const sslRead = Module.findExportByName("libssl.so", "SSL_read");
    if (!sslRead) return;
    
    let responseCount = 0;
    
    Interceptor.attach(sslRead, {
        onEnter: function(args) {
            this.buf = args[1];
            this.len = args[2].toInt32();
        },
        onLeave: function(retval) {
            const len = retval.toInt32();
            if (len > 100 && len < 20000) {
                try {
                    const str = this.buf.readCString(Math.min(len, 500));
                    if (str && (str.includes("HTTP/1.1 200") || str.includes("{") || str.includes("["))) {
                        responseCount++;
                        if (responseCount <= 10) {
                            console.log("\n───────────────────────────────────────────────────────────────");
                            console.log(`📥 RESPONSE (${len} bytes):`);
                            console.log(`   ${str.substring(0, 200)}...`);
                            flowData.responses.push({ type: "game_api_response", size: len, preview: str.substring(0, 200) });
                        }
                    }
                } catch(e) {}
            }
        }
    });
}

// ==================== 7. ESCANEAR MEMÓRIA EM BUSCA DE CHAVES ====================
function scanForKeys() {
    setInterval(() => {
        try {
            const ranges = Process.enumerateRanges({ protection: 'r--', coalesce: true });
            for (let range of ranges) {
                if (range.size > 1024 * 1024) continue;
                try {
                    const pattern = "65 79 4A"; // "eyJ"
                    const matches = Memory.scanSync(range.base, Math.min(range.size, 1024*1024), pattern);
                    for (let match of matches) {
                        try {
                            const str = match.address.readCString(300);
                            const jwt = cleanJWT(str);
                            if (jwt && jwt !== flowData.jwt) {
                                console.log("\n🔑 NOVO JWT ENCONTRADO NA MEMÓRIA!");
                                console.log(`   ${jwt.substring(0, 100)}...`);
                            }
                        } catch(e) {}
                    }
                } catch(e) {}
            }
        } catch(e) {}
    }, 5000);
}

