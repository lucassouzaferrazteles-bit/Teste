# save as: ff_login_final.py
# python ff_login_final.py

import requests
import json
import base64
import struct
import time
import random
from Crypto.Cipher import AES
from Crypto.Util.Padding import pad

# ============================================================================
# CONSTANTES CAPTURADAS
# ============================================================================
UID = "4765511949"
PASSWORD = "EC7424E285BA6496A73CD5668DF93F04539FFE3611C5DC0A5E588247B1BFB21C"

AES_KEY = bytes.fromhex("4fb533b136ef44780fb374721624ba58")
AES_IV = bytes.fromhex("c6cfe71ef171a1334fc8d31506af7065")

CLIENT_ID = 100067
CLIENT_SECRET = "2ee44819e9b4598845141067b281621874d0d5d7af9d8f7e00c1e54715b7d1e3"

# Headers
HEADERS_OAUTH = {
    "User-Agent": "GarenaMSDK/4.0.41(M2006C3LG ;Android 11;pt;BR;app 1.123.1 2019120270;)",
    "Accept": "application/json",
    "Content-Type": "application/json; charset=utf-8",
}

HEADERS_MAJOR = {
    "User-Agent": "Dalvik/2.1.0 (Linux; U; Android 11; M2006C3LG Build/RP1A.200720.011)",
    "Content-Type": "application/octet-stream",
}

# ============================================================================
# FUNÇÃO PARA CRIAR O PAYLOAD DO tcp_SecPlayerLoginReq
# ============================================================================
def build_sec_player_login_req(access_token):
    """
    Constrói o payload baseado na estrutura tcp_SecPlayerLoginReq_Fields
    """
    
    # Campos da estrutura
    area_id = 1  # Brasil
    client_version_code = "6.17.3"
    client_architecture = 2  # 2 = arm64
    is_new_client = 1
    is_reconnect = 0
    
    # Payload em formato JSON (que será criptografado)
    # O jogo envia como protobuf, mas podemos usar JSON
    payload = {
        "area_id": area_id,
        "client_version_code": client_version_code,
        "client_architecture": client_architecture,
        "is_new_client": is_new_client,
        "is_reconnect": is_reconnect,
        "access_token": access_token,
        "uid": UID,
        "timestamp": int(time.time() * 1000),
        "device": {
            "model": "M2006C3LG",
            "brand": "Redmi",
            "android_id": "9b93ca86ba70cfd1"
        }
    }
    
    return json.dumps(payload, separators=(',', ':'))

# ============================================================================
# FUNÇÃO PARA CRIPTOGRAFAR O PAYLOAD
# ============================================================================
def encrypt_payload(data: str) -> bytes:
    """Criptografa o payload com AES-CBC (como o Free Fire faz)"""
    cipher = AES.new(AES_KEY, AES.MODE_CBC, AES_IV)
    padded = pad(data.encode('utf-8'), AES.block_size)
    return cipher.encrypt(padded)

# ============================================================================
# FUNÇÃO PARA DESCRIPTOGRAFAR A RESPOSTA
# ============================================================================
def decrypt_response(encrypted: bytes) -> str:
    """Descriptografa a resposta do MajorLogin"""
    cipher = AES.new(AES_KEY, AES.MODE_CBC, AES_IV)
    decrypted = cipher.decrypt(encrypted)
    # Remover padding PKCS7
    pad_len = decrypted[-1]
    if pad_len <= 16:
        return decrypted[:-pad_len].decode('utf-8', errors='ignore')
    return decrypted.decode('utf-8', errors='ignore')

# ============================================================================
# 1. OAUTH GRANT
# ============================================================================
def get_oauth_token():
    """Passo 1: Obter access_token via OAuth Guest Grant"""
    
    url = "https://100067.connect.garena.com/api/v2/oauth/guest/token:grant"
    
    payload = {
        "client_id": CLIENT_ID,
        "client_secret": CLIENT_SECRET,
        "client_type": 2,
        "password": PASSWORD,
        "response_type": "token",
        "uid": UID
    }
    
    print(f"\n🔐 [1/2] OAuth Grant")
    print(f"   UID: {UID}")
    
    response = requests.post(url, json=payload, headers=HEADERS_OAUTH, timeout=30)
    
    if response.status_code != 200:
        raise Exception(f"OAuth falhou: {response.status_code} - {response.text}")
    
    data = response.json()
    access_token = data.get('access_token')
    
    print(f"   ✅ Access Token: {access_token[:50]}...")
    
    return access_token

# ============================================================================
# 2. MAJOR LOGIN
# ============================================================================
def major_login(access_token):
    """Passo 2: Enviar MajorLogin e obter JWT"""
    
    url = "https://rslw0r.launches.appsflyersdk.com/api/v6.17/androidevent?app_id=com.dts.freefireth&buildnumber=6.17.3"
    
    # Construir payload
    payload_str = build_sec_player_login_req(access_token)
    encrypted = encrypt_payload(payload_str)
    
    print(f"\n🔐 [2/2] MajorLogin")
    print(f"   Payload: {len(payload_str)} bytes")
    print(f"   Criptografado: {len(encrypted)} bytes")
    
    response = requests.post(url, headers=HEADERS_MAJOR, data=encrypted, timeout=30)
    
    print(f"   Status: {response.status_code}")
    
    if response.status_code == 200:
        # Tentar extrair JWT da resposta
        try:
            # Se a resposta estiver criptografada
            decrypted = decrypt_response(response.content)
            print(f"   Resposta: {decrypted[:200]}...")
            
            # Procurar JWT
            import re
            jwt_match = re.search(r'eyJ[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+', decrypted)
            if jwt_match:
                jwt = jwt_match.group()
                print(f"\n✅ JWT OBTIDO!")
                print(f"   {jwt}\n")
                
                # Decodificar
                parts = jwt.split('.')
                payload = json.loads(base64.b64decode(parts[1] + '==').decode())
                print(f"📦 PAYLOAD:")
                print(json.dumps(payload, indent=2))
                return jwt, payload.get('account_id')
        except Exception as e:
            print(f"   Resposta bruta (hex): {response.content[:50].hex()}...")
    
    return None, None

# ============================================================================
# MAIN
# ============================================================================
def main():
    print("╔════════════════════════════════════════════════════════════╗")
    print("║     FREE FIRE - LOGIN FLOW (Baseado no dump.cs)           ║")
    print("╚════════════════════════════════════════════════════════════╝")
    
    try:
        # Passo 1
        access_token = get_oauth_token()
        
        # Passo 2
        jwt, account_id = major_login(access_token)
        
        if jwt:
            print("\n" + "="*60)
            print("✅ LOGIN COMPLETO COM SUCESSO!")
            print("="*60)
            print(f"🆔 Account ID: {account_id}")
            print(f"🔑 JWT: {jwt[:100]}...")
        else:
            print("\n❌ Não foi possível obter o JWT")
            
    except Exception as e:
        print(f"\n❌ Erro: {e}")

if __name__ == "__main__":
    main()
