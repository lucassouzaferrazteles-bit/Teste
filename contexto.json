powershell
# Save as: Decompile-With-ILSpy.ps1
# REQUER: dotnet tool install -g ilspycmd

param(
    [string]$DllPath = ".",
    [string]$OutputDir = "DecompiledCode"
)

Write-Host "========================================" -ForegroundColor Magenta
Write-Host "DECOMPILANDO DLLs COM ILSPY" -ForegroundColor Magenta
Write-Host "========================================" -ForegroundColor Magenta

# Verificar se ilspycmd está instalado
$ilspy = Get-Command ilspycmd -ErrorAction SilentlyContinue

if (-not $ilspy) {
    Write-Host "ILSpyCMD não encontrado. Instalando..." -ForegroundColor Yellow
    & dotnet tool install -g ilspycmd
    
    # Atualizar PATH
    $env:Path = [System.Environment]::GetEnvironmentVariable("Path", "User") + ";" + [System.Environment]::GetEnvironmentVariable("Path", "Machine")
    $ilspy = Get-Command ilspycmd -ErrorAction SilentlyContinue
}

if (-not $ilspy) {
    Write-Host "ERRO: Não foi possível instalar o ILSpyCMD." -ForegroundColor Red
    Write-Host "Instale manualmente: dotnet tool install -g ilspycmd" -ForegroundColor Yellow
    exit
}

# Criar diretório de saída
$fullOutputDir = Join-Path $DllPath $OutputDir
if (-not (Test-Path $fullOutputDir)) {
    New-Item -ItemType Directory -Path $fullOutputDir -Force | Out-Null
}

# Encontrar DLLs principais
$dlls = Get-ChildItem -Path $DllPath -Filter "*.dll" -Recurse | Where-Object { 
    $_.Name -match "Assembly-CSharp|GameAssembly|msdk|garena" 
}

foreach ($dll in $dlls) {
    Write-Host "`nDecompilando: $($dll.Name)" -ForegroundColor Cyan
    
    $outputFolder = Join-Path $fullOutputDir $dll.BaseName
    & ilspycmd $dll.FullName -o $outputFolder
    
    if (Test-Path $outputFolder) {
        Write-Host "  ✓ Decompilado para: $outputFolder" -ForegroundColor Green
        
        # Buscar arquivos com classes de login
        $loginFiles = Get-ChildItem -Path $outputFolder -Filter "*.cs" -Recurse | Select-String -Pattern "Login" -List
        
        if ($loginFiles) {
            Write-Host "  📄 Arquivos com classes de login:" -ForegroundColor Yellow
            foreach ($file in $loginFiles) {
                Write-Host "    - $($file.FullName)"
            }
        }
    }
}

Write-Host "`n========================================" -ForegroundColor Green
Write-Host "DECOMPILAÇÃO CONCLUÍDA!" -ForegroundColor Green
Write-Host "Código fonte salvo em: $fullOutputDir" -ForegroundColor Yellow
Write-Host "========================================" -ForegroundColor Green
