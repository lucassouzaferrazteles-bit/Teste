import requests
import json
import base64
from Crypto.Cipher import AES
from Crypto.Util.Padding import pad

# Configurações
UID = "4765511949"
PASSWORD = "EC7424E285BA6496A73CD5668DF93F04539FFE3611C5DC0A5E588247B1BFB21C"
MAIN_KEY = bytes.fromhex("4fb533b136ef44780fb374721624ba58")
MAIN_IV = bytes.fromhex("c6cfe71ef171a1334fc8d31506af7065")

# 1. OAuth Grant
def get_oauth_token():
    url = "https://100067.connect.garena.com/api/v2/oauth/guest/token:grant"
    payload = {
        "client_id": 100067,
        "client_secret": "2ee44819e9b4598845141067b281621874d0d5d7af9d8f7e00c1e54715b7d1e3",
        "client_type": 2,
        "password": PASSWORD,
        "response_type": "token",
        "uid": UID
    }
    headers = {
        "User-Agent": "GarenaMSDK/4.0.41(M2006C3LG ;Android 11;pt;BR;app 1.123.1 2019120270;)",
        "Content-Type": "application/json"
    }
    response = requests.post(url, json=payload, headers=headers)
    return response.json()

# 2. Criptografar payload
def encrypt_payload(data):
    cipher = AES.new(MAIN_KEY, AES.MODE_CBC, MAIN_IV)
    return cipher.encrypt(pad(data.encode(), AES.block_size))

# 3. MajorLogin
def major_login(access_token):
    url = "https://rslw0r.launches.appsflyersdk.com/api/v6.17/androidevent?app_id=com.dts.freefireth&buildnumber=6.17.3"
    
    payload = {
        "uid": UID,
        "access_token": access_token,
        # ... outros campos do dispositivo
    }
    
    encrypted = encrypt_payload(json.dumps(payload))
    headers = {
        "User-Agent": "Dalvik/2.1.0 (Linux; U; Android 11; M2006C3LG Build/RP1A.200720.011)",
        "Content-Type": "application/octet-stream"
    }
    response = requests.post(url, headers=headers, data=encrypted)
    return response
